` (guaranteed opaque), then\n"}, {"t": "+", "n": 138, "l": "+       * `--toolbox-bgcolor`, then `--tab-selected-bgcolor`.\n"}, {"t": "+", "n": 139, "l": "+       *\n"}, {"t": "+", "n": 140, "l": "+       * We rely on at least one of `--toolbox-bgcolor` / `--tab-selected-bgcolor`\n"}, {"t": "+", "n": 141, "l": "+       * being opaque on the system themes, so even though `--lwt-accent-color` is\n"}, {"t": "+", "n": 142, "l": "+       * not set there, it ends up working out because we never see it through.\n"}, {"t": "+", "n": 143, "l": "+       */\n"}, {"t": "+", "n": 144, "l": "+      background-color: var(--lwt-accent-color);\n"}, {"t": "+", "n": 145, "l": "+      background-image: linear-gradient(var(--tab-selected-bgcolor)), linear-gradient(var(--toolbox-bgcolor));\n"}, {"t": "+", "n": 146, "l": "+      color-scheme: var(--tab-selected-color-scheme);\n"}, {"t": "+", "n": 147, "l": "+      outline-color: var(--tab-selected-outline-color);\n"}, {"t": "+", "n": 148, "l": "+      box-shadow: var(--tab-selected-shadow);\n"}, {"t": "+", "n": 149, "l": "+      border-radius: var(--border-radius-circle);\n"}, {"t": "+", "n": 150, "l": "+      display: block;\n"}, {"t": "+", "n": 151, "l": "+      position: absolute;\n"}, {"t": "+", "n": 152, "l": "+      inset: auto;\n"}, {"t": "+", "n": 153, "l": "+      top: -1px;\n"}, {"t": "+", "n": 154, "l": "+      inset-inline-start: 2px;\n"}, {"t": "+", "n": 155, "l": "+\n"}, {"t": "+", "n": 156, "l": "+      .browser-toolbox-background:-moz-window-inactive & {\n"}, {"t": "+", "n": 157, "l": "+        background-image: linear-gradient(var(--tab-selected-bgcolor)), linear-gradient(var(--toolbox-bgcolor-inactive));\n"}, {"t": "+", "n": 158, "l": "+      }\n"}, {"t": "+", "n": 159, "l": "+\n"}, {"t": "+", "n": 160, "l": "+      .tabbrowser-tab:is([selected], :hover) & {\n"}, {"t": "+", "n": 161, "l": "+        opacity: 1;\n"}, {"t": "+", "n": 162, "l": "+      }\n"}, {"t": "", "n": 163, "l": "     }\n"}, {"t": "", "n": 164, "l": "   