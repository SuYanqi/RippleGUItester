[{"node": "3b597e62bd28015328688468f817ad50d4d42106", "date": [1736607146.0, 0], "desc": "Bug 1933479 - Add tab close button on hover to vertical tabs when sidebar is collapsed r=desktop-theme-reviewers,tabbrowser-reviewers,sidebar-reviewers,nsharpley,emilio,dao\n\nDifferential Revision: https://phabricator.services.mozilla.com/D232561", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Kelly Cochrane <kcochrane@mozilla.com>", "parents": ["c72899901f29c51caa57cb3b84518041a9952e18"], "children": ["fd23343643397f9956843d50242cd1957e7d1c18"], "files": [{"file": "browser/components/sidebar/tests/browser/browser.toml", "status": "modified"}, {"file": "browser/components/sidebar/tests/browser/browser_sidebar_collapsed_close_tab_button.js", "status": "added"}, {"file": "browser/themes/shared/tabbrowser/tabs.css", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/components/sidebar/tests/browser/browser.toml\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/components/sidebar/tests/browser/browser.toml\n"}, {"t": "@", "n": 3, "l": "@@ -17,16 +17,18 @@ prefs = [\n"}, {"t": "", "n": 4, "l": " [\"browser_glean_sidebar.js\"]\n"}, {"t": "", "n": 5, "l": " \n"}, {"t": "", "n": 6, "l": " [\"browser_hide_sidebar_on_popup.js\"]\n"}, {"t": "", "n": 7, "l": " \n"}, {"t": "", "n": 8, "l": " [\"browser_history_sidebar.js\"]\n"}, {"t": "", "n": 9, "l": " \n"}, {"t": "", "n": 10, "l": " [\"browser_resize_sidebar.js\"]\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "+", "n": 12, "l": "+[\"browser_sidebar_collapsed_close_tab_button.js\"]\n"}, {"t": "+", "n": 13, "l": "+\n"}, {"t": "", "n": 14, "l": " [\"browser_sidebar_context_menu.js\"]\n"}, {"t": "", "n": 15, "l": " \n"}, {"t": "", "n": 16, "l": " [\"browser_sidebar_macmenu.js\"]\n"}, {"t": "", "n": 17, "l": " run-if = [\"os == 'mac'\"] # Mac only feature\n"}, {"t": "", "n": 18, "l": " \n"}, {"t": "", "n": 19, "l": " [\"browser_sidebar_max_width.js\"]\n"}, {"t": "", "n": 20, "l": " \n"}, {"t": "", "n": 21, "l": " [\"browser_sidebar_menubar_item_commands.js\"]\n"}]}, {"blockno": 2, "lines": [{"t": "", "n": 1, "l": "new file mode 100644\n"}, {"t": "-", "n": 2, "l": "--- /dev/null\n"}, {"t": "+", "n": 3, "l": "+++ b/browser/components/sidebar/tests/browser/browser_sidebar_collapsed_close_tab_button.js\n"}, {"t": "@", "n": 4, "l": "@@ -0,0 +1,83 @@\n"}, {"t": "+", "n": 5, "l": "+/* Any copyright is dedicated to the Public Domain.\n"}, {"t": "+", "n": 6, "l": "+   https://creativecommons.org/publicdomain/zero/1.0/ */\n"}, {"t": "+", "n": 7, "l": "+\n"}, {"t": "+", "n": 8, "l": "+\"use strict\";\n"}, {"t": "+", "n": 9, "l": "+\n"}, {"t": "+", "n": 10, "l": "+add_setup(async () => {\n"}, {"t": "+", "n": 11, "l": "+  await SpecialPowers.pushPrefEnv({\n"}, {"t": "+", "n": 12, "l": "+    set: [\n"}, {"t": "+", "n": 13, "l": "+      [\"sidebar.verticalTabs\", true],\n"}, {"t": "+", "n": 14, "l": "+      [\"sidebar.visibility\", \"always-show\"],\n"}, {"t": "+", "n": 15, "l": "+    ],\n"}, {"t": "+", "n": 16, "l": "+  });\n"}, {"t": "+", "n": 17, "l": "+});\n"}, {"t": "+", "n": 18, "l": "+registerCleanupFunction(async () => {\n"}, {"t": "+", "n": 19, "l": "+  await SpecialPowers.popPrefEnv();\n"}, {"t": "+", "n": 20, "l": "+  gBrowser.removeAllTabsBut(gBrowser.tabs[0]);\n"}, {"t": "+", "n": 21, "l": "+});\n"}, {"t": "+", "n": 22, "l": "+\n"}, {"t": "+", "n": 23, "l": "+add_task(async function test_toggle_collapse_close_button() {\n"}, {"t": "+", "n": 24, "l": "+  const sidebar = document.querySelector(\"sidebar-main\");\n"}, {"t": "+", "n": 25, "l": "+  ok(sidebar, \"Sidebar is shown.\");\n"}, {"t": "+", "n": 26, "l": "+\n"}, {"t": "+", "n": 27, "l": "+  if (window.SidebarController._state.launcherExpanded) {\n"}, {"t": "+", "n": 28, "l": "+    await SidebarController.initializeUIState({ launcherExpanded: false });\n"}, {"t": "+", "n": 29, "l": "+    await sidebar.updateComplete;\n"}, {"t": "+", "n": 30, "l": "+  }\n"}, {"t": "+", "n": 31, "l": "+  ok(!sidebar.expanded, \"Sidebar is collapsed by default.\");\n"}, {"t": "+", "n": 32, "l": "+\n"}, {"t": "+", "n": 33, "l": "+  let newTabButton = document.getElementById(\"tabs-newtab-button\");\n"}, {"t": "+", "n": 34, "l": "+  info(\"Open a new tab using the new tab button.\");\n"}, {"t": "+", "n": 35, "l": "+  EventUtils.synthesizeMouseAtCenter(newTabButton, {});\n"}, {"t": "+", "n": 36, "l": "+  is(gBrowser.tabs.length, 2, \"Tabstrip now has two tabs\");\n"}, {"t": "+", "n": 37, "l": "+\n"}, {"t": "+", "n": 38, "l": "+  let firstTab = gBrowser.visibleTabs[0];\n"}, {"t": "+", "n": 39, "l": "+  let computedStyle = window.getComputedStyle(\n"}, {"t": "+", "n": 40, "l": "+    gBrowser.selectedTab.querySelector(\".tab-close-button\")\n"}, {"t": "+", "n": 41, "l": "+  );\n"}, {"t": "+", "n": 42, "l": "+  is(computedStyle.opacity, \"1\", \"The active tab is showing the close button.\");\n"}, {"t": "+", "n": 43, "l": "+\n"}, {"t": "+", "n": 44, "l": "+  computedStyle = window.getComputedStyle(\n"}, {"t": "+", "n": 45, "l": "+    firstTab.querySelector(\".tab-close-button\")\n"}, {"t": "+", "n": 46, "l": "+  );\n"}, {"t": "+", "n": 47, "l": "+  is(\n"}, {"t": "+", "n": 48, "l": "+    computedStyle.opacity,\n"}, {"t": "+", "n": 49, "l": "+    \"0\",\n"}, {"t": "+", "n": 50, "l": "+    \"The inactive tab is not showing the close button.\"\n"}, {"t": "+", "n": 51, "l": "+  );\n"}, {"t": "+", "n": 52, "l": "+\n"}, {"t": "+", "n": 53, "l": "+  // Check that collapsed close button is shown on hover of the inactive tab\n"}, {"t": "+", "n": 54, "l": "+  EventUtils.synthesizeMouse(firstTab, 10, 10, { type: \"mouseover\" });\n"}, {"t": "+", "n": 55, "l": "+  computedStyle = window.getComputedStyle(\n"}, {"t": "+", "n": 56, "l": "+    firstTab.querySelector(\".tab-close-button\")\n"}, {"t": "+", "n": 57, "l": "+  );\n"}, {"t": "+", "n": 58, "l": "+  is(\n"}, {"t": "+", "n": 59, "l": "+    computedStyle.opacity,\n"}, {"t": "+", "n": 60, "l": "+    \"1\",\n"}, {"t": "+", "n": 61, "l": "+    \"The inactive tab is showing the close button on hover.\"\n"}, {"t": "+", "n": 62, "l": "+  );\n"}, {"t": "+", "n": 63, "l": "+  // The tab can be closed via the keyboard shortcut, this button is not focusable\n"}, {"t": "+", "n": 64, "l": "+  AccessibilityUtils.setEnv({ focusableRule: false });\n"}, {"t": "+", "n": 65, "l": "+  // Close the active tab\n"}, {"t": "+", "n": 66, "l": "+  EventUtils.synthesizeMouseAtCenter(\n"}, {"t": "+", "n": 67, "l": "+    gBrowser.selectedTab.querySelector(\".tab-close-button\"),\n"}, {"t": "+", "n": 68, "l": "+    {}\n"}, {"t": "+", "n": 69, "l": "+  );\n"}, {"t": "+", "n": 70, "l": "+  AccessibilityUtils.resetEnv();\n"}, {"t": "+", "n": 71, "l": "+  is(gBrowser.tabs.length, 1, \"Tabstrip now has one tab\");\n"}, {"t": "+", "n": 72, "l": "+\n"}, {"t": "+", "n": 73, "l": "+  // Expand the sidebar and make sure the collased close button no longer shows\n"}, {"t": "+", "n": 74, "l": "+  await SidebarController.initializeUIState({ launcherExpanded: true });\n"}, {"t": "+", "n": 75, "l": "+  await sidebar.updateComplete;\n"}, {"t": "+", "n": 76, "l": "+  await TestUtils.waitForCondition(() => {\n"}, {"t": "+", "n": 77, "l": "+    return window.SidebarController._state.launcherExpanded;\n"}, {"t": "+", "n": 78, "l": "+  }, \"Sidebar launcher is expanded\");\n"}, {"t": "+", "n": 79, "l": "+  computedStyle = window.getComputedStyle(\n"}, {"t": "+", "n": 80, "l": "+    gBrowser.selectedTab.querySelector(\".tab-close-button\")\n"}, {"t": "+", "n": 81, "l": "+  );\n"}, {"t": "+", "n": 82, "l": "+  is(\n"}, {"t": "+", "n": 83, "l": "+    computedStyle.position,\n"}, {"t": "+", "n": 84, "l": "+    \"static\",\n"}, {"t": "+", "n": 85, "l": "+    \"The active tab is  showing the collapsed close button when the sidebar is expanded.\"\n"}, {"t": "+", "n": 86, "l": "+  );\n"}, {"t": "+", "n": 87, "l": "+});\n"}]}, {"blockno": 3, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/themes/shared/tabbrowser/tabs.css\n"}, {"t": "+", "n": 2, "l