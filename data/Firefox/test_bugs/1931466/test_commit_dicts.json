[{"node": "e2242ed908c0f7637c2b9277a674d5d0e1bcd09f", "date": [1732110316.0, 0], "desc": "Bug 1931466: Ensure inline elements in an empty linebox as having zero BSize and no baseline. r=layout-reviewers,dholbert,jfkthame\n\nAlso add meta viewport tag to the setup of `/FileAPI/url/url-in-tags.window.js`\nWPT - This test passes now, but without this change, the test's viewport gets\nautomatically zoomed out when run on Android; and that zoom factor can lead to\noff-by-one test failures from pixel-rounding discrepancies.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D229191", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "David Shin <dshin@mozilla.com>", "parents": ["dd8c7c0aa4dfd22d8b4d86212269360a1d2d6550"], "children": ["00bd39b32a73d8d1105293386ec91871aabd94a4"], "files": [{"file": "layout/generic/nsBlockFrame.cpp", "status": "modified"}, {"file": "layout/generic/nsFirstLetterFrame.cpp", "status": "modified"}, {"file": "layout/generic/nsInlineFrame.cpp", "status": "modified"}, {"file": "layout/generic/nsLineLayout.cpp", "status": "modified"}, {"file": "layout/generic/nsLineLayout.h", "status": "modified"}, {"file": "layout/generic/nsRubyBaseContainerFrame.cpp", "status": "modified"}, {"file": "layout/reftests/css-ui/caret-color-01-ref.html", "status": "modified"}, {"file": "layout/reftests/css-visited/caret-color-on-visited-1-ref.html", "status": "modified"}, {"file": "testing/web-platform/meta/FileAPI/url/url-in-tags.window.js.ini", "status": "modified"}, {"file": "testing/web-platform/meta/css/CSS2/positioning/abspos-inline-008.xht.ini", "status": "removed"}, {"file": "testing/web-platform/meta/css/CSS2/positioning/toogle-abspos-on-relpos-inline-child.html.ini", "status": "removed"}, {"file": "testing/web-platform/meta/css/css-break/out-of-flow-in-multicolumn-116.html.ini", "status": "removed"}, {"file": "testing/web-platform/meta/css/css-position/position-absolute-in-inline-001.html.ini", "status": "removed"}, 