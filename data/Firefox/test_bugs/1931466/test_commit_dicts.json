 to know this before reflowing the first\n"}, {"t": "", "n": 22, "l": "   // inline frame in the line. FIX ME.\n"}, {"t": "", "n": 23, "l": "   if (0 == aLineLayout.GetLineNumber() &&\n"}, {"t": "", "n": 24, "l": "       HasAllStateBits(NS_BLOCK_HAS_FIRST_LETTER_CHILD |\n"}]}, {"blockno": 2, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/generic/nsFirstLetterFrame.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/generic/nsFirstLetterFrame.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -217,19 +217,21 @@ void nsFirstLetterFrame::Reflow(nsPresCo\n"}, {"t": "", "n": 4, "l": "     // When there is no lineLayout provided, we provide our own. The\n"}, {"t": "", "n": 5, "l": "     // only time that the first-letter-frame is not reflowing in a\n"}, {"t": "", "n": 6, "l": "     // line context is when its floating.\n"}, {"t": "", "n": 7, "l": "     WritingMode kidWritingMode = WritingModeForLine(wm, kid);\n"}, {"t": "", "n": 8, "l": "     LogicalSize kidAvailSize = availSize.ConvertTo(kidWritingMode, wm);\n"}, {"t": "", "n": 9, "l": "     ReflowInput rs(aPresContext, aReflowInput, kid, kidAvailSize);\n"}, {"t": "", "n": 10, "l": "     nsLineLayout ll(aPresContext, nullptr, aReflowInput, nullptr, nullptr);\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "+", "n": 12, "l": "+    // This frame does not get constructed for an empty inline frame, so\n"}, {"t": "+", "n": 13, "l": "+    // `CollapseEmptyInlineFramesInLine` should not matter.\n"}, {"t": "", "n": 14, "l": "     ll.BeginLineReflow(\n"}, {"t": "", "n": 15, "l": "         bp.IStart(wm), bp.BStart(wm), availSize.ISize(wm), NS_UNCONSTRAINEDSIZE,\n"}, {"t": "-", "n": 16, "l": "-        false, true, kidWritingMode,\n"}, {"t": "+", "n": 17, "l": "+        false, true, CollapseEmptyInlineFramesInLine::Collapse, kidWritingMode,\n"}, {"t": "", "n": 18, "l": "         nsSize(aReflowInput.AvailableWidth(), aReflowInput.AvailableHeight()));\n"}, {"t": "", "n": 19, "l": "     rs.mLineLayout = &ll;\n"}, {"t": "", "n": 20, "l": "     ll.SetInFirstLetter(true);\n"}, {"t": "", "n": 21, "l": "     ll.SetFirstLetterStyleOK(true);\n"}, {"t": "", "n": 22, "l": " \n"}, {"t": "", "n": 23, "l": "     kid->Reflow(aPresContext, kidMetrics, rs, aReflowStatus);\n"}, {"t": "", "n": 24, "l": " \n"}, {"t": "", "n": 25, "l": "     ll.EndLineReflow();\n"}]}, {"blockno": 3, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/generic/nsInlineFrame.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/generic/nsInlineFrame.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -845,16 +845,18 @@ LogicalSides nsInlineFrame::GetLogicalSk\n"}, {"t": "", "n": 4, "l": " }\n"}, {"t": "", "n": 5, "l": " \n"}, {"t": "", "n": 6, "l": " Maybe<nscoord> nsInlineFrame::GetNaturalBaselineBOffset(\n"}, {"t": "", "n": 7, "l": "     WritingMode aWM, BaselineSharingGroup aBaselineGroup,\n"}, {"t": "", "n": 8, "l": "     BaselineExportContext) const {\n"}, {"t": "", "n": 9, "l": "   if (aBaselineGroup == BaselineSharingGroup::Last) {\n"}, {"t": "", "n": 10, "l": "     return Nothing{};\n"}, {"t": "", "n": 11, "l": "   }\n"}, {"t": "+", "n": 12, "l": "+  // TODO(dshin): Some functions seem to rely on this returning\n"}, {"t": "+", "n": 13, "l": "+  // NS_INTRINSIC_ISIZE_UNKNOWN. e.g. /css/css-pseudo/target-text-008.html\n"}, {"t": "", "n": 14, "l": "   return Some(mBaseline);\n"}, {"t": "", "n": 15, "l": " }\n"}, {"t": "", "n": 16, "l": " \n"}, {"t": "", "n": 17, "l": " #ifdef ACCESSIBILITY\n"}, {"t": "", "n": 18, "l": " a11y::AccType nsInlineFrame::AccessibleType() {\n"}, {"t": "", "n": 19, "l": "   // FIXME(emilio): This is broken, if the image has its default `display` value\n"}, {"t": "", "n": 20, "l": "   // overridden. Should be somewhere else.\n"}, {"t": "", "n": 21, "l": "   if (mContent->IsHTMLElement(\n"}]}, {"blockno": 4, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/generic/nsLineLayout.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/generic/nsLineLayout.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -86,22 +86,21 @@ nsLineLayout::nsLineLayout(nsPresContext\n"}, {"t": "", "n": 4, "l": "       nsLayoutUtils::InflationMinFontSizeFor(LineContainerFrame());\n"}, {"t": "", "n": 5, "l": " \n"}, {"t": "", "n": 6, "l": "   if (aLine) {\n"}, {"t": "", "n": 7, "l": "     mGotLineBox = true;\n"}, {"t": "", "n": 8, "l": "     mLineBox = *aLine;\n"}, {"t": "", "n": 9, "l": "   }\n"}, {"t": "", "n": 10, "l": " }\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "-", "n": 12, "l": "-void nsLineLayout::BeginLineReflow(nscoord aICoord, nscoord aBCoord,\n"}, {"t": "-", "n": 13, "l": "-                                   nscoord aISize, nscoord aBSize,\n"}, {"t": "-", "n": 14, "l": "-                                   bool aImpactedByFloats, bool aIsTopOfPage,\n"}, {"t": "-", "n": 15, "l": "-                                   WritingMode aWritingMode,\n"}, {"t": "-", "n": 16, "l": "-                                   const nsSize& aContainerSize,\n"}, {"t": "-", "n": 17, "l": "-                                   nscoord aInset) {\n"}, {"t": "+", "n": 18, "l": "+void nsLineLayout::BeginLineReflow(\n"}, {"t": "+", "n": 19, "l": "+    nscoord aICoord, nscoord aBCoord, nscoord aISize, nscoord aBSize,\n"}, {"t": "+", "n": 20, "l": "+    bool aImpactedByFloats, bool aIsTopOfPage,\n"}, {"t": "+", "n": 21, "l": "+    CollapseEmptyInlineFramesInLine aCollapseEmptyInlineFramesInLine,\n"}, {"t": "+", "n": 22, "l": "+    WritingMode aWritingMode, const nsSize& aContainerSize, nscoord aInset) {\n"}, {"t": "", "n": 23, "l": "   MOZ_ASSERT(nullptr == mRootSpan, \"bad linelayout user\");\n"}, {"t": "", "n": 24, "l": "   LAYOUT_WARN_IF_FALSE(aISize != NS_UNCONSTRAINEDSIZE,\n"}, {"t": "", "n": 25, "l": "                        \"have unconstrained width; this should only result from \"\n"}, {"t": "", "n": 26, "l": "                        \"very large sizes, not attempts at intrinsic width \"\n"}, {"t": "", "n": 27, "l": "                        \"calculation\");\n"}, {"t": "", "n": 28, "l": " #ifdef DEBUG\n"}, {"t": "", "n": 29, "l": "   if ((aISize != NS_UNCONSTRAINEDSIZE) && ABSURD_SIZE(aISize) &&\n"}, {"t": "", "n": 30, "l": "       !LineContainerFrame()->GetParent()->IsAbsurdSizeAssertSuppressed()) {\n"}, {"t": "@", "n": 31, "l": "@@ -144,16 +143,19 @@ void nsLineLayout::BeginLineReflow(nscoo\n"}, {"t": "", "n": 32, "l": "   }\n"}, {"t": "", "n": 33, "l": " \n"}, {"t": "", "n": 34, "l": "   PerSpanData* psd = NewPerSpanData();\n"}, {"t": "", "n": 35, "l": "   mCurrentSpan = mRootSpan = psd;\n"}, {"t": "", "n": 36, "l": "   psd->mReflowInput = &mLineContainerRI;\n"}, {"t": "", "n": 37, "l": "   psd->mIStart = aICoord;\n"}, {"t": "", "n": 38, "l": "   psd->mICoord = aICoord;\n"}, {"t": "", "n": 39, "l": "   psd->mIEnd = aICoord + aISize;\n"}, {"t": "+", "n": 40, "l": "+  psd->mDoCollapseEmptyInlineFramesInLine =\n"}, {"t": "+", "n": 41, "l": "+      aCollapseEmptyInlineFramesInLine ==\n"}, {"t": "+", "n": 42, "l": "+      CollapseEmptyInlineFramesInLine::Collapse;\n"}, {"t": "", "n": 43, "l": "   // Set up inset to be used for text-wrap:balance implementation, but only if\n"}, {"t": "", "n": 44, "l": "   // the available size is greater than inset.\n"}, {"t": "", "n": 45, "l": "   psd->mInset = aISize > aInset ? aInset : 0;\n"}, {"t": "", "n": 46, "l": "   mContainerSize = aContainerSize;\n"}, {"t": "", "n": 47, "l": " \n"}, {"t": "", "n": 48, "l": "   mBStartEdge = aBCoord;\n"}, {"t": "", "n": 49, "l": " \n"}, {"t": "", "n": 50, "l": "   psd->mNoWrap = !mStyleText->WhiteSpaceCanWrapStyle() || mSuppressLineWrap;\n"}, {"t": "@", "n": 51, "l": "@@ -349,16 +351,17 @@ nsLineLayout::PerSpanData* nsLineLayout:\n"}, {"t": "", "n": 52, "l": "   psd->mParent = nullptr;\n"}, {"t": "", "n": 53, "l": "   psd->mFrame = nullptr;\n"}, {"t": "", "n": 54, "l": "   psd->mFirstFrame = nullptr;\n"}, {"t": "", "n": 55, "l": "   psd->mLastFrame = nullptr;\n"}, {"t": "", "n": 56, "l": "   psd->mReflowInput = nullptr;\n"}, {"t": "", "n": 57, "l": "   psd->mContainsFloat = false;\n"}, {"t": "", "n": 58, "l": "   psd->mHasNonemptyContent = false;\n"}, {"t": "", "n": 59, "l": "   psd->mBaseline = nullptr;\n"}, {"t": "+", "n": 60, "l": "+  psd->mDoCollapseEmptyInlineFramesInLine = false;\n"}, {"t": "", "n": 61, "l": " \n"}, {"t": "", "n": 62, "l": " #ifdef DEBUG\n"}, {"t": "", "n": 63, "l": "   outerLineLayout->mSpansAllocated++;\n"}, {"t": "", "n": 64, "l": " #endif\n"}, {"t": "", "n": 65, "l": "   return psd;\n"}, {"t": "", "n": 66, "l": " }\n"}, {"t": "", "n": 67, "l": " \n"}, {"t": "", "n": 68, "l": " void nsLineLayout::BeginSpan(nsIFrame* aFrame,\n"}, {"t": "@", "n": 69, "l": "@@ -1485,16 +1488,44 @@ bool nsLineLayout::NotifyOptionalBreakPo\n"}, {"t": "", "n": 70, "l": " #define VALIGN_TOP 1\n"}, {"t": "", "n": 71, "l": " #define VALIGN_BOTTOM 2\n"}, {"t": "", "n": 72, "l": " \n"}, {"t": "", "n": 73, "l": " void nsLineLayout::VerticalAlignLine() {\n"}, {"t": "", "n": 74, "l": "   // Partially place the children of the block frame. The baseline for\n"}, {"t": "", "n": 75, "l": "   // this operation is set to zero so that the y coordinates for all\n"}, {"t": "", "n": 76, "l": "   // of the placed children will be relative to there.\n"}, {"t": "", "n": 77, "l": "   PerSpanData* psd = mRootSpan;\n"}, {"t": "+", "n": 78, "l": "+  if (mLineIsEmpty && psd->mDoCollapseEmptyInlineFramesInLine) {\n"}, {"t": "+", "n": 79, "l": "+    // This line is empty, and should be consisting of only inline elements.\n"}, {"t": "+", "n": 80, "l": "+    // (inline-block elements would make the line non-empty).\n"}, {"t": "+", "n": 81, "l": "+    WritingMode lineWM = psd->mWritingMode;\n"}, {"t": "+", "n": 82, "l": "+    for (PerFrameData* pfd = psd->mFirstFrame; pfd; pfd = pfd->mNext) {\n"}, {"t": "+", "n": 83, "l": "+      // Ideally, if the frame would collapse itself - but it depends on\n"}, {"t": "+", "n": 84, "l": "+      // knowing that the line is empty.\n"}, {"t": "+", "n": 85, "l": "+      if (!pfd->mFrame->IsInlineFrame() && !pfd->mFrame->IsRubyFrame()) {\n"}, {"t": "+", "n": 86, "l": "+        continue;\n"}, {"t": "+", "n": 87, "l": "+      }\n"}, {"t": "+", "n": 88, "l": "+      // Collapse the physical size to 0.\n"}, {"t": "+", "n": 89, "l": "+      pfd->mBounds.BStart(lineWM) = mBStartEdge;\n"}, {"t": "+", "n": 90, "l": "+      pfd->mBounds.BSize(lineWM) = 0;\n"}, {"t": "+", "n": 91, "l": "+      // Initialize mBlockDirAlign (though it doesn't make much difference\n"}, {"t": "+", "n": 92, "l": "+      // because we don't align empty boxes).\n"}, {"t": "+", "n": 93, "l": "+      pfd->mBlockDirAlign = VALIGN_OTHER;\n"}, {"t": "+", "n": 94, "l": "+      pfd->mFrame->SetRect(lineWM, pfd->mBounds, ContainerSize());\n"}, {"t": "+", "n": 95, "l": "+    }\n"}, {"t": "+", "n": 96, "l": "+\n"}, {"t": "+", "n": 97, "l": "+    mFinalLineBSize = 0;\n"}, {"t": "+", "n": 98, "l": "+    if (mGotLineBox) {\n"}, {"t": "+", "n": 99, "l": "+      mLineBox->SetBounds(psd->mWritingMode, psd->mIStart, mBStartEdge,\n"}, {"t": "+", "n": 100, "l": "+                          psd->mICoord - psd->mIStart, 0, ContainerSize());\n"}, {"t": "+", "n": 101, "l": "+\n"}, {"t": "+", "n": 102, "l": "+      mLineBox->SetLogicalAscent(0);\n"}, {"t": "+", "n": 103, "l": "+    }\n"}, {"t": "+", "n": 104, "l": "+    return;\n"}, {"t": "+", "n": 105, "l": "+  }\n"}, {"t": "", "n": 106, "l": "   VerticalAlignFrames(psd);\n"}, {"t": "", "n": 107, "l": " \n"}, {"t": "", "n": 108, "l": "   // *** Note that comments here still use the anachronistic term\n"}, {"t": "", "n": 109, "l": "   // \"line-height\" when we really mean \"size of the line in the block\n"}, {"t": "", "n": 110, "l": "   // direction\", \"vertical-align\" when we really mean \"alignment in\n"}, {"t": "", "n": 111, "l": "   // the block direction\", and \"top\" and \"bottom\" when we really mean\n"}, {"t": "", "n": 112, "l": "   // \"block start\" and \"block end\". This is partly for brevity and\n"}, {"t": "", "n": 113, "l": "   // partly to retain the association with the CSS line-height and\n"}]}, {"blockno": 5, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/generic/n