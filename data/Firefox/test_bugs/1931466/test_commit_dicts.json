, "n": 19, "l": "+<!-- Empty inline element in empty line has a height of zero. -->\n"}, {"t": "+", "n": 20, "l": "+<div class=\"container\"><ruby class=\"inline\"></ruby></div><br>\n"}, {"t": "+", "n": 21, "l": "+<!-- ... But not if the line has a meaningful height. -->\n"}, {"t": "+", "n": 22, "l": "+<div class=\"container\"><ruby class=\"inline\"></ruby><ruby class=\"has-height\"></ruby><ruby class=\"inline\"></ruby></div><br>\n"}]}], "phase": "public", "pushid": 42336, "pushdate": [1732122722, 0], "pushuser": "nfay@mozilla.com", "landingsystem": "lando", "git_commit": null}, {"node": "160977ed2e6cd8576c70840d388d1a6bcfc07262", "date": [1732198217.0, 0], "desc": "Bug 1931466: Ensure inline elements inside an empty line has zero block-size and no baseline in scrolled block frames. r=layout-reviewers,dholbert\n\nDifferential Revision: https://phabricator.services.mozilla.com/D229709", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "David Shin <dshin@mozilla.com>", "parents": ["a27c4a10c8655ff0caebab5aa97d474a89fc1d89"], "children": ["c1a15d8f1a23b026bb4e33c2adf5871e41d9a776"], "files": [{"file": "layout/generic/nsBlockFrame.cpp", "status": "modified"}, {"file": "testing/web-platform/tests/css/css-inline/empty-span-size-001-ref.html", "status": "modified"}, {"file": "testing/web-platform/tests/css/css-inline/empty-span-size-001.html", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/generic/nsBlockFrame.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/generic/nsBlockFrame.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -4983,23 +4983,37 @@ void nsBlockFrame::DoReflowInlineFrames(\n"}, {"t": "", "n": 4, "l": "     /* XXX get the height right! */\n"}, {"t": "", "n": 5, "l": "     availBSize = lineRect.BSize(lineWM);\n"}, {"t": "", "n": 6, "l": "   }\n"}, {"t": "", "n": 7, "l": " \n"}, {"t": "", "n": 8, "l": "   // Make sure to enable resize optimization before we call BeginLineReflow\n"}, {"t": "", "n": 9, "l": "   // because it might get disabled there\n"}, {"t": "", "n": 10, "l": "   aLine->EnableResizeReflowOptimization();\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "-", "n": 12, "l": "-  aLineLayout.BeginLineReflow(\n"}, {"t": "-", "n": 13, "l": "-      iStart, aState.mBCoord, availISize, availBSize,\n"}, {"t": "-", "n": 14, "l": "-      aFloatAvailableSpace.HasFloats(), false /*XXX isTopOfPage*/,\n"}, {"t": "-", "n": 15, "l": "-      HasOutsideMarker() || Style()->IsAnonBox()\n"}, {"t": "+", "n": 16, "l": "+  // We want to be able to collapse the height of empty inline elements in empty\n"}, {"t": "+", "n": 17, "l": "+  // lines in general - See [1]. Two exceptions:\n"}, {"t": "+", "n": 18, "l": "+  // 1. There is an outside ::marker frame, which is physical on this line, but\n"}, {"t": "+", "n": 19, "l": "+  //    is not part of the line layout.\n"}, {"t": "+", "n": 20, "l": "+  // 2. The line is inside an anonymous box, like `<input type=button>`. A\n"}, {"t": "+", "n": 21, "l": "+  //    scrolled block frame internally has an anonymous box of the scrolled\n"}, {"t": "+", "n": 22, "l": "+  //    content, which we still want to carry out the collapsing for.\n"}, {"t": "+", "n": 23, "l": "+  //\n"}, {"t": "+", "n": 24, "l": "+  // [1]: https://drafts.csswg.org/css-inline-3/#invisible-line-boxes\n"}, {"t": "+", "n": 25, "l": "+  auto collapseEmptyInlineFramesInLine =\n"}, {"t": "+", "n": 26, "l": "+      HasOutsideMarker() ||\n"}, {"t": "+", "n": 27, "l": "+              (Style()->IsAnonBox() &&\n"}, {"t": "+", "n": 28, "l": "+               Style()->GetPseudoType() != PseudoStyleType::scrolledContent)\n"}, {"t": "", "n": 29, "l": "           ? CollapseEmptyInlineFramesInLine::Preserve\n"}, {"t": "-", "n": 30, "l": "-          : CollapseEmptyInlineFramesInLine::Collapse,\n"}, {"t": "-", "n": 31, "l": "-      lineWM, aState.mContainerSize, aState.mInsetForBalance);\n"}, {"t": "+", "n": 32, "l": "+          : CollapseEmptyInlineFramesInLine::Collapse;\n"}, {"t": "+", "n": 33, "l": "+\n"}, {"t": "+", "n": 34, "l": "+  aLineLayout.BeginLineReflow(iStart, aState.mBCoord, availISize, availBSize,\n"}, {"t": "+", "n": 35, "l": "+                              aFloatAvailableSpace.HasFloats(),\n"}, {"t": "+", "n": 36, "l": "+                              false /*XXX isTopOfPage*/,\n"}, {"t": "+", "n": 37, "l": "+                              collapseEmptyInlineFramesInLine, lineWM,\n"}, {"t": "+", "n": 38, "l": "+                              aState.mContainerSize, aState.mInsetForBalance);\n"}, {"t": "", "n": 39, "l": " \n"}, {"t": "", "n": 40, "l": "   aState.mFlags.mIsLineLayoutEmpty = false;\n"}, {"t": "", "n": 41, "l": " \n"}, {"t": "", "n": 42, "l": "   // XXX Unfortunately we need to know this before reflowing the first\n"}, {"t": "", "n": 43, "l": "   // inline frame in the line. FIX ME.\n"}, {"t": "", "n": 44, "l": "   if (0 == aLineLayout.GetLineNumber() &&\n"}, {"t": "", "n": 45, "l": "       HasAllStateBits(NS_BLOCK_HAS_FIRST_LETTER_CHILD |\n"}, {"t": "", "n": 46, "l": "                       NS_BLOCK_HAS_FIRST_LETTER_STYLE)) {\n"}]}, {"blockno": 2, "lines": [{"t": "-", "n": 1, "l": "--- a/testing/web-platform/tests/css/css-inline/empty-span-size-001-ref.html\n"}, {"t": "+", "n": 2, "l": "+++ b/testing/web-platform/tests/css/css-inline/empty-span-size-001-ref.html\n"}, {"t": "@", "n": 3, "l": "@@ -2,25 +2,36 @@\n"}, {"t": "", "n": 4, "l": " <link rel=\"author\" title=\"David Shin\" href=\"mailto:dshin@mozilla.com\">\n"}, {"t": "", "n": 5, "l": " <link rel=\"help\" href=\"https://drafts.csswg.org/css-inline-3/#invisible-line-boxes\">\n"}, {"t": "", "n": 6, "l": " <link rel=\"help\" href=\"https://bugzilla.mozilla.org/show_bug.cgi?id=1931466\">\n"}, {"t": "", "n": 7, "l": " <style>\n"}, {"t": "", "n": 8, "l": " .container {\n"}, {"t": "", "n": 9, "l": "   border: 1px solid;\n"}, {"t": "", "n": 10, "l": " }\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "+", "n": 12, "l": "+.oa {\n"}, {"t": "+", "n": 13, "l": "+  height: 100px;\n"}, {"t": "+", "n": 14, "l": "+}\n"}, {"t": "+", "n": 15, "l": "+\n"}, {"t": "+", "n": 16, "l": "+.filler {\n"}, {"t": "+", "n": 17, "l": "+  height: 100px;\n"}, {"t": "+", "n": 18, "l": "+  box-sizing: border-box;\n"}, {"t": "+", "n": 19, "l": "+  border: 1px solid;\n"}, {"t": "+", "n": 20, "l": "+}\n"}, {"t": "+", "n": 21, "l": "+\n"}, {"t": "", "n": 22, "l": " ul {\n"}, {"t": "", "n": 23, "l": "   margin: 0;\n"}, {"t": "", "n": 24, "l": " }\n"}, {"t": "", "n": 25, "l": " \n"}, {"t": "", "n": 26, "l": " .button {\n"}, {"t": "", "n": 27, "l": "   box-sizing: border-box;\n"}, {"t": "", "n": 28, "l": "   border-left: 1px solid;\n"}, {"t": "", "n": 29, "l": "   width: 1px;\n"}, {"t": "", "n": 30, "l": "   height: 11px;\n"}, {"t": "", "n": 31, "l": "   display: inline-block;\n"}, {"t": "", "n": 32, "l": "   vertical-align: top;\n"}, {"t": "", "n": 33, "l": " }\n"}, {"t": "", "n": 34, "l": " </style>\n"}, {"t": "", "n": 35, "l": " <div class=\"container\"></div><br>\n"}, {"t": "+", "n": 36, "l": "+<div class=\"container oa\"><div class=\"filler\"></div></div><br>\n"}, {"t": "", "n": 37, "l": " <div class=\"container\"><span style=\"border: 1px solid; border-right: 2px solid;\"></span></div><br>\n"}, {"t": "", "n": 38, "l": " <div class=\"container\"><ul><li>&nbsp;</li><li>&nbsp;</li></ul></div><br>\n"}, {"t": "", "n": 39, "l": " <div class=\"container\"><div class=\"button\"></div><span>&nbsp;</span></div><br>\n"}]}, {"blockno": 3, "lines": [{"t": "-", "n": 1, "l": "--- a/testing/web-platform/tests/css/css-inline/empty-span-size-001.html\n"}, {"t": "+", "n": 2, "l": "+++ b/testing/web-platform/tests/css/css-inline/empty-span-size-001.html\n"}, {"t": "@", "n": 3, "l": "@@ -1,9 +1,10 @@\n"}, {"t": "", "n": 4, "l": " <!DOCTYPE html>\n"}, {"t": "+", "n": 5, "l": "+<html class=reftest-wait>\n"}, {"t": "", "n": 6, "l": " <link rel=\"author\" title=\"David Shin\" href=\"mailto:dshin@mozilla.com\">\n"}, {"t": "", "n": 7, "l": " <link rel=\"help\" href=\"https://drafts.csswg.org/css-inline-3/#invisible-line-boxes\">\n"}, {"t": "", "n": 8, "l": " <link rel=\"help\" href=\"https://bugzilla.mozilla.org/show_bug.cgi?id=1931466\">\n"}, {"t": "", "n": 9, "l": " <link rel=\"match\" href=\"empty-span-size-001-ref.html\">\n"}, {"t": "", "n": 10, "l": " <style>\n"}, {"t": "", "n": 11, "l": " .container, .has-height {\n"}, {"t": "", "n": 12, "l": "   border: 1px solid;\n"}, {"t": "", "n": 13, "l": " }\n"}, {"t": "@", "n": 14, "l": "@@ -16,23 +17,50 @@ input {\n"}, {"t": "", "n": 15, "l": "   outline: 1px solid;\n"}, {"t": "", "n": 16, "l": "   background: transparent;\n"}, {"t": "", "n": 17, "l": "   padding: 0;\n"}, {"t": "", "n": 18, "l": "   border: 0;\n"}, {"t": "", "n": 19, "l": "   line-height: 10px;\n"}, {"t": "", "n": 20, "l": "   vertical-align: top;\n"}, {"t": "", "n": 21, "l": " }\n"}, {"t": "", "n": 22, "l": " \n"}, {"t": "+", "n": 23, "l": "+.oa {\n"}, {"t": "+", "n": 24, "l": "+  overflow: hidden;\n"}, {"t": "+", "n": 25, "l": "+  height: 100px;\n"}, {"t": "+", "n": 26, "l": "+}\n"}, {"t": "+", "n": 27, "l": "+\n"}, {"t": "+", "n": 28, "l": "+.filler {\n"}, {"t": "+", "n": 29, "l": "+  height: 100px;\n"}, {"t": "+", "n": 30, "l": "+  box-sizing: border-box;\n"}, {"t": "+", "n": 31, "l": "+  border: 1px solid;\n"}, {"t": "+", "n": 32, "l": "+}\n"}, {"t": "+", "n": 33, "l": "+\n"}, {"t": "+", "n": 34, "l": "+.bad {\n"}, {"t": "+", "n": 35, "l": "+  background: red;\n"}, {"t": "+", "n": 36, "l": "+}\n"}, {"t": "+", "n": 37, "l": "+\n"}, {"t": "", "n": 38, "l": " ul {\n"}, {"t": "", "n": 39, "l": "   margin: 0;\n"}, {"t": "", "n": 40, "l": " }\n"}, {"t": "", "n": 41, "l": " \n"}, {"t": "", "n": 42, "l": " li {\n"}, {"t": "", "n": 43, "l": "   width: 0;\n"}, {"t": "", "n": 44, "l": " }\n"}, {"t": "+", "n": 45, "l": "+\n"}, {"t": "", "n": 46, "l": " </style>\n"}, {"t": "", "n": 47, "l": " <!-- Empty inline element in empty line has a height of zero. -->\n"}, {"t": "", "n": 48, "l": " <div class=\"container\"><span class=\"inline\"></span></div><br>\n"}, {"t": "+", "n": 49, "l": "+<!-- Empty inline element should not contribute to scrollable overflow. -->\n"}, {"t": "+", "n": 50, "l": "+<div class=\"container oa\">\n"}, {"t": "+", "n": 51, "l": "+  <div class=\"filler bad\"></div>\n"}, {"t": "+", "n": 52, "l": "+  <span id=\"scrollTarget\"></span>\n"}, {"t": "+", "n": 53, "l": "+  <div class=\"filler\"></div>\n"}, {"t": "+", "n": 54, "l": "+</div><br>\n"}, {"t": "", "n": 55, "l": " <!-- ... But not if the line has a meaningful height. -->\n"}, {"t": "", "n": 56, "l": " <div class=\"container\"><span class=\"inline\"></span><span class=\"has-height\"></span><span class=\"inline\"></span></div><br>\n"}, {"t": "", "n": 57, "l": " <!-- ... Or if the line is present in some kind of context that gives a meaningful height. -->\n"}, {"t": "", "n": 58, "l": " <div class=\"container\"><ul><li></li><li></li></ul></div><br>\n"}, {"t": "", "n": 59, "l": " <div class=\"container\"><input type=\"button\" value=\"\"></div><br>\n"}, {"t": "+", "n": 60, "l": "+<script>\n"}, {"t": "+", "n": 61, "l": "+scrollTarget.scrollIntoView();\n"}, {"t": "+", "n": 62, "l": "+document.documentElement.className = \"\";\n"}, {"t": "+", "n": 63, "l": "+</script>\n"}, {"t": "+", "n": 64, "l": "+</html>\n"}]}], "phase": "public", "pushid": 42340, "pushdate": [1732225974, 0], "pushuser": "agoloman@mozilla.com", "landingsystem": "lando", "git_commit": null}]