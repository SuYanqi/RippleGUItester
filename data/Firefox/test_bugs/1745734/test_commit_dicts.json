[{"node": "e2a09f7c430ea6f7d06fadf270f5093136621826", "date": [1732620501.0, 0], "desc": "Bug 1745734 - Fix styling of insecure warning. r=desktop-theme-reviewers,dao\n\n--grey-60 doesn't exist in browser chrome, so `color` behaves as\ncurrentColor, and `fill` as `initial` which is black.\n\nWithout this rule fill is already currentColor due to the general\n.ac-site-icon rules.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D230234", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Emilio Cobos \u00c1lvarez <emilio@crisal.io>", "parents": ["e6f1ff3702cb37c8f402577cb55cfd544c02f049"], "children": ["2cdcde7eda9fde67552bd8977cf58030958907c6"], "files": [{"file": "browser/themes/shared/autocomplete.css", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/themes/shared/autocomplete.css\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/themes/shared/autocomplete.css\n"}, {"t": "@", "n": 3, "l": "@@ -239,36 +239,32 @@\n"}, {"t": "", "n": 4, "l": "   /* Insecure field warning */\n"}, {"t": "", "n": 5, "l": "   &[originaltype=\"insecureWarning\"] {\n"}, {"t": "", "n": 6, "l": "     background-color: var(--arrowpanel-dimmed);\n"}, {"t": "", "n": 7, "l": "     border-bottom: 1px solid var(--panel-separator-color);\n"}, {"t": "", "n": 8, "l": "     padding-block: 4px;\n"}, {"t": "", "n": 9, "l": " \n"}, {"t": "", "n": 10, "l": "     &[selected] {\n"}, {"t": "", "n": 11, "l": "       background-color: var(--arrowpanel-dimmed-further);\n"}, {"t": "-", "n": 12, "l": "-      color: -moz-DialogText;\n"}, {"t": "", "n": 13, "l": "     }\n"}, {"t": "", "n": 14, "l": " \n"}, {"t": "", "n": 15, "l": "     > .ac-title {\n"}, {"t": "-", "n": 16, "l": "-      color: var(--grey-60);\n"}, {"t": "", "n": 17, "l": "       font-size: 1em;\n"}, {"t": "", "n": 18, "l": "     }\n"}, {"t": "", "n": 19, "l": " \n"}, {"t": "", "n": 20, "l": "     > .ac-title .ac-emphasize-text-title {\n"}, {"t": "", "n": 21, "l": "       font-weight: 600;\n"}, {"t": "", "n": 22, "l": "     }\n"}, {"t": "", "n": 23, "l": " \n"}, {"t": "", "n": 24, "l": "     &[selected] > .ac-title {\n"}, {"t": "", "n": 25, "l": "       color: inherit;\n"}, {"t": "", "n": 26, "l": "     }\n"}, {"t": "", "n": 27, "l": " \n"}, {"t": "", "n": 28, "l": "     > .ac-site-icon {\n"}, {"t": "", "n": 29, "l": "       list-style-image: url(chrome://global/skin/icons/security-broken.svg);\n"}, {"t": "-", "n": 30, "l": "-      -moz-context-properties: fill;\n"}, {"t": "-", "n": 31, "l": "-      fill: var(--grey-60);\n"}, {"t": "", "n": 32, "l": "     }\n"}, {"t": "", "n": 33, "l": "   }\n"}, {"t": "", "n": 34, "l": " }\n"}, {"t": "", "n": 35, "l": " \n"}, {"t": "", "n": 36, "l": " /* Popup states */\n"}, {"t": "", "n": 37, "l": " .autocomplete-richlistitem {\n"}, {"t": "", "n": 38, "l": "   &:not([disabled=\"true\"]):not([selected]):hover {\n"}, {"t": "", "n": 39, "l": "     background-color: var(--arrowpanel-dimmed);\n"}]}], "phase": "public", "pushid": 42355, "pushdate": [1732679880, 0], "pushuser": "agoloman@mozilla.com", "landingsystem": "lando"}]