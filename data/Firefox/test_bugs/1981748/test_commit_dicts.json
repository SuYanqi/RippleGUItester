[{"node": "d43deabb3880ea4f48eb3e46023751cb6cfa6ec6", "date": [1754577078.0, 0], "desc": "Bug 1981748 - Avoid building the top layer past the 255th page. r=dshin\n\nThis patch makes sure that top layer display items that we build for a\ngiven page are uniquely tagged with the page number, which avoids\nuniqueness assertion failures with the patch from bug 1972694.\n\nIn theory this could also trivially happen by printing a modal <dialog>\nor so, but it currently doesn't, see bug 1981732.\n\nThe patch in bug 1972694 exposes this on a devtools test\n(browser_browser_toolbox_print_preview.js) because we start creating an\nisolation container for the DevTools anonymous content, which is in the\ntop layer, and we currently didn't set the page number in the\nViewportFrame::BuildDisplayList which ends up building it, failing our\nunique display item assertions.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D260270\n", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Emilio Cobos \u00c1lvarez <emilio@crisal.io>", "parents": ["82776e4e0e5070d7bf2c1c894e57207fe8c43038"], "children": ["874fc080b31697904e65ad0ad80ef76ba408bdb4"], "files": [{"file": "layout/generic/ViewportFrame.cpp", "status": "modified"}, {"file": "layout/generic/nsPageContentFrame.cpp", "status": "modified"}, {"file": "layout/painting/nsDisplayList.cpp", "status": "modified"}, {"file": "layout/painting/nsDisplayList.h", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/generic/ViewportFrame.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/generic/ViewportFrame.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -206,16 +206,20 @@ nsDisplayWrapList* ViewportFrame::MaybeW\n"}, {"t": "", "n": 4, "l": "   }\n"}, {"t": "", "n": 5, "l": "   wrapList->SetOverrideZIndex(\n"}, {"t": "", "n": 6, "l": "       std::numeric_limits<decltype(wrapList->ZIndex())>::max());\n"}, {"t": "", "n": 7, "l": "   return wrapList;\n"}, {"t": "", "n": 8, "l": " }\n"}, {"t": "", "n": 9, "l": " \n"}, {"t": "", "n": 10, "l": " nsDisplayWrapList* ViewportFrame::BuildDisplayListForContentTopLayer(\n"}, {"t": "", "n": 11, "l": "     nsDisplayListBuilder* aBuilder, bool* aIsOpaque) {\n"}, {"t": "+", "n": 12, "l": "+  if (aBuilder->AvoidBuildingDuplicateOofs()) {\n"}, {"t": "+", "n": 13, "l": "+    return nullptr;\n"}, {"t": "+", "n": 14, "l": "+  }\n"}, {"t": "+", "n": 15, "l": "+\n"}, {"t": "", "n": 16, "l": "   nsDisplayList topLayerList(aBuilder);\n"}, {"t": "", "n": 17, "l": "   auto* doc = PresContext()->Document();\n"}, {"t": "", "n": 18, "l": " \n"}, {"t": "", "n": 19, "l": "   nsTArray<dom::Element*> topLayer = doc->GetTopLayer();\n"}, {"t": "", "n": 20, "l": "   for (dom::Element* elem : topLayer) {\n"}, {"t": "", "n": 21, "l": "     nsIFrame* frame = elem->GetPrimaryFrame();\n"}, {"t": "", "n": 22, "l": "     if (!frame) {\n"}, {"t": "", "n": 23, "l": "       continue;\n"}, {"t": "@", "n": 24, "l": "@@ -276,16 +280,20 @@ nsDisplayWrapList* ViewportFrame::BuildD\n"}, {"t": "", "n": 25, "l": " \n"}, {"t": "", "n": 26, "l": "   return MaybeWrapTopLayerList(aBuilder, uint16_t(TopLayerIndex::Content),\n"}, {"t": "", "n": 27, "l": "                                topLayerList);\n"}, {"t": "", "n": 28, "l": " }\n"}, {"t": "", "n": 29, "l": " \n"}, {"t": "", "n": 30, "l": " nsDisplayWrapList*\n"}, {"t": "", "n": 31, "l": " ViewportFrame::BuildDisplayListForViewTransitionsAndNACTopLayer(\n"}, {"t": "", "n": 32, "l": "     nsDisplayListBuilder* aBuilder) {\n"}, {"t": "+", "n": 33, "l": "+  if (aBuilder->AvoidBuildingDuplicateOofs()) {\n"}, {"t": "+", "n": 34, "l": "+    return nullptr;\n"}, {"t": "+", "n": 35, "l": "+  }\n"}, {"t": "+", "n": 36, "l": "+\n"}, {"t": "", "n": 37, "l": "   nsDisplayList topLayerList(aBuilder);\n"}, {"t": "", "n": 38, "l": "   auto* doc = PresContext()->Document();\n"}, {"t": "", "n": 39, "l": "   if (dom::ViewTransition* vt = doc->GetActiveViewTransition()) {\n"}, {"t": "", "n": 40, "l": "     if (dom::Element* root = vt->GetSnapshotContainingBlock()) {\n"}, {"t": "", "n": 41, "l": "       if (nsIFrame* frame = root->GetPrimaryFrame()) {\n"}, {"t": "", "n": 42, "l": "         MOZ_ASSERT(frame->StyleDisplay()->mTopLayer != StyleTopLayer::None,\n"}, {"t": "", "n": 43, "l": "                    \"the snapshot containing block should ensure this\");\n"}, {"t": "", "n": 44, "l": "         MOZ_ASSERT(frame->HasAnyStateBits(NS_FRAME_OUT_OF_FLOW));\n"}]}, {"blockno": 2, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/generic/nsPageContentFrame.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/generic/nsPageContentFrame.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -314,38 +314,43 @@ nsIFrame::ComputeTransformFunction nsPag\n"}, {"t": "", "n": 4, "l": "   return ComputePageContentTransform;\n"}, {"t": "", "n": 5, "l": " }\n"}, {"t": "", "n": 6, "l": " \n"}, {"t": "", "n": 7, "l": " void nsPageContentFrame::BuildDisplayList(nsDisplayListBuilder* aBuilder,\n"}, {"t": "", "n": 8, "l": "                                           const nsDisplayListSet& aLists) {\n"}, {"t": "", "n": 9, "l": "   MOZ_ASSERT(GetParent());\n"}, {"t": "", "n": 10, "l": "   MOZ_ASSERT(GetParent()->IsPageFrame());\n"}, {"t": "", "n": 11, "l": "   auto* pageFrame = static_cast<nsPageFrame*>(GetParent());\n"}, {"t": "-", "n": 12, "l": "-  auto pageNum = pageFrame->GetPageNum();\n"}, {"t": "-", "n": 13, "l": "-  NS_ASSERTION(pageNum <= 255, \"Too many pages to handle OOFs\");\n"}, {"t": "", "n": 14, "l": " \n"}, {"t": "-", "n": 15, "l": "-  if (aBuilder->GetBuildingExtraPagesForPageNum()) {\n"}, {"t": "+", "n": 16, "l": "+  if (auto pageNum = aBuilder->GetBuildingPageNum()) {\n"}, {"t": "+", "n": 17, "l": "+    // We're an extra page, avoid building duplicate OOFs that are going to be\n"}, {"t": "+", "n": 18, "l": "+    // built already.\n"}, {"t": "+", "n": 19, "l": "+    nsDisplayListBuilder::AutoPageNumberSetter p(\n"}, {"t": "+", "n": 20, "l": "+        aBuilder, pageNum, /* aAvoidBuildingDuplicateOofs = */ true);\n"}, {"t": "", "n": 21, "l": "     return mozilla::ViewportFrame::BuildDisplayList(aBuilder, aLists);\n"}, {"t": "", "n": 22, "l": "   }\n"}, {"t": "", "n": 23, "l": " \n"}, {"t": "", "n": 24, "l": "   nsDisplayListCollection set(aBuilder);\n"}, {"t": "", "n": 25, "l": " \n"}, {"t": "", "n": 26, "l": "   nsDisplayList content(aBuilder);\n"}, {"t": "", "n": 27, "l": "   {\n"}, {"t": "+", "n": 28, "l": "+    nsDisplayListBuilder::AutoPageNumberSetter p(aBuilder,\n"}, {"t": "+", "n": 29, "l": "+                                                 pageFrame->GetPageNum());\n"}, {"t": "+", "n": 30, "l": "+    NS_ASSERTION(!aBuilder->AvoidBuildingDuplicateOofs(),\n"}, {"t": "+", "n": 31, "l": "+                 \"Too many pages to handle OOFs\");\n"}, {"t": "", "n": 32, "l": "     const nsRect clipRect(aBuilder->ToReferenceFrame(this), GetSize());\n"}, {"t": "", "n": 33, "l": "     DisplayListClipState::AutoSaveRestore clipState(aBuilder);\n"}, {"t": "", "n": 34, "l": " \n"}, {"t": "", "n": 35, "l": "     // Overwrite current clip, since we're going to wrap in a transform and the\n"}, {"t": "", "n": 36, "l": "     // current clip is no longer meaningful.\n"}, {"t": "", "n": 37, "l": "     clipState.Clear();\n"}, {"t": "", "n": 38, "l": "     clipState.ClipContentDescendants(clipRect);\n"}, {"t": "", "n": 39, "l": " \n"}, {"t": "", "n": 40, "l": "     if (StaticPrefs::layout_display_list_improve_fragmentation() &&\n"}, {"t": "-", "n": 41, "l": "-        pageNum <= 255) {\n"}, {"t": "-", "n": 42, "l": "-      nsDisplayListBuilder::AutoPageNumberSetter p(aBuilder, pageNum);\n"}, {"t": "+", "n": 43, "l": "+        !aBuilder->AvoidBuildingDuplicateOofs()) {\n"}, {"t": "", "n": 44, "l": "       BuildPreviousPageOverflow(aBuilder, pageFrame, this, set);\n"}, {"t": "", "n": 45, "l": "     }\n"}, {"t": "", "n": 46, "l": "     mozilla::ViewportFrame::BuildDisplayList(aBuilder, set);\n"}, {"t": "", "n": 47, "l": " \n"}, {"t": "", "n": 48, "l": "     set.SerializeWithCorrectZOrder(&content, GetContent());\n"}, {"t": "", "n": 49, "l": " \n"}, {"t": "", "n": 50, "l": "     // We may need to paint out-of-flow frames whose placeholders are on other\n"}, {"t": "", "n": 51, "l": "     // pages. Add those pages to our display list. Note that out-of-flow frames\n"}, {"t": "@", "n": 52, "l": "@@ -355,20 +360,18 @@ void nsPageContentFrame::BuildDisplayLis\n"}, {"t": "", "n": 53, "l": "     // page we currently care about (which we would have reached by\n"}, {"t": "", "n": 54, "l": "     // following placeholders to their out-of-flows) end up on the list.\n"}, {"t": "", "n": 55, "l": "     //\n"}, {"t": "", "n": 56, "l": "     // Stacking context frames that wrap content on their normal page,\n"}, {"t": "", "n": 57, "l": "     // as well as OOF content for this page will have their container\n"}, {"t": "", "n": 58, "l": "     // items duplicated. We tell the builder to include our page number\n"}, {"t": "", "n": 59, "l": "     // in the unique key for any extra page items so that they can be\n"}, {"t": "", "n": 60, "l": "     // differentiated from the ones created on the normal page.\n"}, {"t": "-", "n": 61, "l": "-    if (pageNum <= 255) {\n"}, {"t": "+", "n": 62, "l": "+    if (!aBuilder->AvoidBuildingDuplicateOofs()) {\n"}, {"t": "", "n": 63, "l": "       const nsRect overflowRect = ScrollableOverflowRectRelativeToSelf();\n"}, {"t": "-", "n": 64, "l": "-      nsDisplayListBuilder::AutoPageNumberSetter p(aBuilder, pageNum);\n"}, {"t": "-", "n": 65, "l": "-\n"}, {"t": "", "n": 66, "l": "       // The static_cast here is technically unnecessary, but it helps\n"}, {"t": "", "n": 67, "l": "       // devirtualize the GetNextContinuation() function call if pcf has a\n"}, {"t": "", "n": 68, "l": "       // concrete type (with an inherited `final` GetNextContinuation() impl).\n"}, {"t": "", "n": 69, "l": "       auto* pageCF = this;\n"}, {"t": "", "n": 70, "l": "       while ((pageCF = static_cast<nsPageContentFrame*>(\n"}, {"t": "", "n": 71, "l": "                   pageCF->GetNextContinuation()))) {\n"}, {"t": "", "n": 72, "l": "         nsRect childVisible = overflowRect + GetOffsetTo(pageCF);\n"}, {"t": "", "n": 73, "l": " \n"}]}, {"blockno": 3, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/painting/nsDisplayList.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/painting/nsDisplayList.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -691,17 +691,16 @@ nsDisplayListBuilder::nsDisplayListBuild\n"}, {"t": "", "n": 4, "l": "       mCurrentReferenceFrame(aReferenceFrame),\n"}, {"t": "", "n": 5, "l": "       mScrollInfoItemsForHoisting(nullptr),\n"}, {"t": "", "n": 6, "l": "       mFirstClipChainToDestroy(nullptr),\n"}, {"t": "", "n": 7, "l": "       mTableBackgroundSet(nullptr),\n"}, {"t": "", "n": 8, "l": "       mCurrentScrollParentId(ScrollableLayerGuid::NULL_SCROLL_ID),\n"}, {"t": "", "n": 9, "l": "       mCurrentScrollbarTarget(ScrollableLayerGuid::NULL_SCROLL_ID),\n"}, {"t": "", "n": 10, "l": "       mFilterASR(nullptr),\n"}, {"t": "", "n": 11, "l": "       mDirtyRect(-1, -1, -1, -1),\n"}, {"t": "-", "n": 12, "l": "-      mBuildingExtraPagesForPageNum(0),\n"}, {"t": "", "n": 13, "l": "       mMode(aMode),\n"}, {"t": "", "n": 14, "l": "       mIsBuildingScrollbar(false),\n"}, {"t": "", "n": 15, "l": "       mCurrentScrollbarWillHaveLayer(false),\n"}, {"t": "", "n": 16, "l": "       mBuildCaret(aBuildCaret),\n"}, {"t": "", "n": 17, "l": "       mRetainingDisplayList(aRetainingDisplayList),\n"}, {"t": "", "n": 18, "l": "       mPartialUpdate(false),\n"}, {"t": "", "n": 19, "l": "       mIgnoreSuppression(false),\n"}, {"t": "", "n": 20, "l": "       mIncludeAllOutOfFlows(false),\n"}]}, {"blockno": 4, "lines": [{"t": "-", "n": 1, "l": "--- a/layout/painting/nsDisplayList.h\n"}, {"t": "+", "n": 2, "l": "+++ b/layout/painting/nsDisplayList.h\n"}, {"t": "@", "n": 3, "l": "@@ -1292,32 +1292,37 @@ class nsDisplayListBuilder {\n"}, {"t": "", "n": 4, "l": "       mBuilder->mCurrentScrollbarWillHaveLayer = false;\n"}, {"t": "", "n": 5, "l": "     }\n"}, {"t": "", "n": 6, "l": " \n"}, {"t": "", "n": 7, "l": "    private:\n"}, {"t": "", "n": 8, "l": "     nsDisplayListBuilder* mBuilder;\n"}, {"t": "", "n": 9, "l": "   };\n"}, {"t": "", "n": 10, "l": " \n"}, {"t": "", "n": 11, "l": "   /**\n"}, {"t": "-", "n": 12, "l": "-   * A helper class to temporarily set mBuildingExtraPagesForPageNum.\n"}, {"t": "+", "n": 13, "l": "+   * A helper class to temporarily set mPageNum.\n"}, {"t": "", "n": 14, "l": "    */\n"}, {"t": "", "n": 15, "l": "   class MOZ_RAII AutoPageNumberSetter {\n"}, {"t": "", "n": 16, "l": "    public:\n"}, {"t": "-", "n": 17, "l": "-    AutoPageNumberSetter(nsDisplayListBuilder* aBuilder, const uint8_t aPageNum)\n"}, {"t": "+", "n": 18, "l": "+    AutoPageNumberSetter(nsDisplayListBuilder* aBuilder, int32_t aPageNum,\n"}, {"t": "+", "n": 19, "l": "+                         bool aAvoidBuildingDuplicateOofs = false)\n"}, {"t": "", "n": 20, "l": "         : mBuilder(aBuilder),\n"}, {"t": "-", "n": 21, "l": "-          mOldPageNum(aBuilder->GetBuildingExtraPagesForPageNum()) {\n"}, {"t": "-", "n": 22, "l": "-      mBuilder->SetBuildingExtraPagesForPageNum(aPageNum);\n"}, {"t": "+", "n": 23, "l": "+          mOldPageNum(aBuilder->GetBuildingPageNum()),\n"}, {"t": "+", "n": 24, "l": "+          mOldAvoid(aBuilder->AvoidBuildingDuplicateOofs()) {\n"}, {"t": "+", "n": 25, "l": "+      mBuilder->SetBuildingPageNum(\n"}, {"t": "+", "n": 26, "l": "+          uint8_t(std::min(aPageNum, 255)),\n"}, {"t": "+", "n": 27, "l": "+          aAvoidBuildingDuplicateOofs || aPageNum > 255);\n"}, {"t": "", "n": 28, "l": "     }\n"}, {"t": "", "n": 29, "l": "     ~AutoPageNumberSetter() {\n"}, {"t": "-", "n": 30, "l": "-      mBuilder->SetBuildingExtraPagesForPageNum(mOldPageNum);\n"}, {"t": "+", "n": 31, "l": "+      mBuilder->SetBuildingPageNum(mOldPageNum, mOldAvoid);\n"}, {"t": "", "n": 32, "l": "     }\n"}, {"t": "", "n": 33, "l": " \n"}, {"t": "", "n": 34, "l": "    private:\n"}, {"t": "", "n": 35, "l": "     nsDisplayListBuilder* mBuilder;\n"}, {"t": "", "n": 36, "l": "     uint8_t mOldPageNum;\n"}, {"t": "+", "n": 37, "l": "+    bool mOldAvoid;\n"}, {"t": "", "n": 38, "l": "   };\n"}, {"t": "", "n": 39, "l": " \n"}, {"t": "", "n": 40, "l": "   /**\n"}, {"t": "", "n": 41, "l": "    * A helper class to track current effective transform for items.\n"}, {"t": "", "n": 42, "l": "    *\n"}, {"t": "", "n": 43, "l": "    * For frames that is Combines3DTransformWithAncestors(), we need to\n"}, {"t": "", "n": 44, "l": "    * apply all transforms of ancestors on the same preserves3D chain\n"}, {"t": "", "n": 45, "l": "    * on the bounds of current frame to the coordination of the 3D\n"}, {"t": "@", "n": 46, "l": "@@ -1617,22 +1622,26 @@ class nsDisplayListBuilder {\n"}, {"t": "", "n": 47, "l": "   }\n"}, {"t": "", "n": 48, "l": " \n"}, {"t": "", "n": 49, "l": "   bool IsBuildingInvisibleItems() const { return mBuildingInvisibleItems; }\n"}, {"t": "", "n": 50, "l": " \n"}, {"t": "", "n": 51, "l": "   void SetBuildingInvisibleItems(bool aBuildingInvisibleItems) {\n"}, {"t": "", "n": 52, "l": "     mBuildingInvisibleItems = aBuildingInvisibleItems;\n"}, {"t": "", "n": 53, "l": "   }\n"}, {"t": "", "n": 54, "l": " \n"}, {"t": "-", "n": 55, "l": "-  void SetBuildingExtraPagesForPageNum(uint8_t aPageNum) {\n"}, {"t": "-", "n": 56, "l": "-    mBuildingExtraPagesForPageNum = aPageNum;\n"}, {"t": "-", "n": 57, "l": "-  }\n"}, {"t": "-", "n": 58, "l": "-  uint8_t GetBuildingExtraPagesForPageNum() const {\n"}, {"t": "-", "n": 59, "l": "-    return mBuildingExtraPagesForPageNum;\n"}, {"t": "-", "n": 60, "l": "-  }\n"}, {"t": "+", "n": 61, "l": "+  void SetBuildingPageNum(uint8_t aPageNum, bool aAvoidBuildingDuplicateOofs) {\n"}, {"t": "+", "n": 62, "l": "+    mBuildingPageNum = aPageNum;\n"}, {"t": "+", "n": 63, "l": "+    mAvoidBuildingDuplicateOofs = aAvoidBuildingDuplicateOofs;\n"}, {"t": "+", "n": 64, "l": "+  }\n"}, {"t": "+", "n": 65, "l": "+\n"}, {"t": "+", "n": 66, "l": "+  bool AvoidBuildingDuplicateOofs() const {\n"}, {"t": "+", "n": 67, "l": "+    return mAvoidBuildingDuplicateOofs;\n"}, {"t": "+", "n": 68, "l": "+  }\n"}, {"t": "+", "n": 69, "l": "+\n"}, {"t": "+", "n": 70, "l": "+  uint8_t GetBuildingPageNum() const { return mBuildingPageNum; }\n"}, {"t": "", "n": 71, "l": " \n"}, {"t": "", "n": 72, "l": "   bool HitTestIsForVisibility() const { return mVisibleThreshold.isSome(); }\n"}, {"t": "", "n": 73, "l": " \n"}, {"t": "", "n": 74, "l": "   float VisibilityThreshold() const {\n"}, {"t": "", "n": 75, "l": "     MOZ_DIAGNOSTIC_ASSERT(HitTestIsForVisibility());\n"}, {"t": "", "n": 76, "l": "     return mVisibleThreshold.valueOr(1.0f);\n"}, {"t": "", "n": 77, "l": "   }\n"}, {"t": "", "n": 78, "l": " \n"}, {"t": "@", "n": 79, "l": "@@ -1910,17 +1919,17 @@ class nsDisplayListBuilder {\n"}, {"t": "", "n": 80, "l": " \n"}, {"t": "", "n": 81, "l": "   // Relative to mCurrentFrame.\n"}, {"t": "", "n": 82, "l": "   nsRect mVisibleRect;\n"}, {"t": "", "n": 83, "l": "   nsRect mDirtyRect;\n"}, {"t": "", "n": 84, "l": "   nsRect mCaretRect;\n"}, {"t": "", "n": 85, "l": " \n"}, {"t": "", "n": 86, "l": "   Preserves3DContext mPreserves3DCtx;\n"}, {"t": "", "n": 87, "l": " \n"}, {"t": "-", "n": 88, "l": "-  uint8_t mBuildingExtraPagesForPageNum;\n"}, {"t": "+", "n": 89, "l": "+  uint8_t mBuildingPageNum = 0;\n"}, {"t": "", "n": 90, "l": " \n"}, {"t": "", "n": 91, "l": "   nsDisplayListBuilderMode mMode;\n"}, {"t": "", "n": 92, "l": "   static uint32_t sPaintSequenceNumber;\n"}, {"t": "", "n": 93, "l": " \n"}, {"t": "", "n": 94, "l": "   uint32_t mNumActiveScrollframesEncountered = 0;\n"}, {"t": "", "n": 95, "l": " \n"}, {"t": "", "n": 96, "l": "   StackingContextBits mStackingContextBits{0};\n"}, {"t": "", "n": 97, "l": "   bool mIsBuildingScrollbar;\n"}, {"t": "@", "n": 98, "l": "@@ -1962,16 +1971,25 @@ class nsDisplayListBuilder {\n"}, {"t": "", "n": 99, "l": "   bool mIsInActiveDocShell;\n"}, {"t": "", "n": 100, "l": "   bool mBuildAsyncZoomContainer;\n"}, {"t": "", "n": 101, "l": "   bool mIsRelativeToLayoutViewport;\n"}, {"t": "", "n": 102, "l": "   bool mUseOverlayScrollbars;\n"}, {"t": "", "n": 103, "l": "   bool mAlwaysLayerizeScrollbars;\n"}, {"t": "", "n": 104, "l": " \n"}, {"t": "", "n": 105, "l": "   bool mIsReusingStackingContextItems;\n"}, {"t": "", "n": 106, "l": "   bool mIsDestroying;\n"}, {"t": "+", "n": 107, "l": "+  // We need to build display items for the same frame in a bunch of situations\n"}, {"t": "+", "n": 108, "l": "+  // in paged mode:\n"}, {"t": "+", "n": 109, "l": "+  //  * When building overflow from a previous page.\n"}, {"t": "+", "n": 110, "l": "+  //  * When building the top layer.\n"}, {"t": "+", "n": 111, "l": "+  // In those cases, we can't deal with building them past the 255th page,\n"}, {"t": "+", "n": 112, "l": "+  // because we use the page number as a differentiator in a uint8_t. When we go\n"}, {"t": "+", "n": 113, "l": "+  // over that page, we set this flag to avoid building potentially duplicate\n"}, {"t": "+", "n": 114, "l": "+  // display items.\n"}, {"t": "+", "n": 115, "l": "+  bool mAvoidBuildingDuplicateOofs = false;\n"}, {"t": "", "n": 116, "l": " \n"}, {"t": "", "n": 117, "l": "   Maybe<layers::ScrollDirection> mCurrentScrollbarDirection;\n"}, {"t": "", "n": 118, "l": " };\n"}, {"t": "", "n": 119, "l": " \n"}, {"t": "", "n": 120, "l": " // All types are defined in nsDisplayItemTypes.h\n"}, {"t": "", "n": 121, "l": " #define NS_DISPLAY_DECL_NAME(n, e)                                           \\\n"}, {"t": "", "n": 122, "l": "   const char* Name() const override { return n; }                            \\\n"}, {"t": "", "n": 123, "l": "   constexpr static DisplayItemType ItemType() { return DisplayItemType::e; } \\\n"}, {"t": "@", "n": 124, "l": "@@ -2040,17 +2058,17 @@ MOZ_ALWAYS_INLINE T* MakeDisplayItemWith\n"}, {"t": "", "n": 125, "l": " \n"}, {"t": "", "n": 126, "l": "   T* item = new (aBuilder) T(aBuilder, aFrame, std::forward<Args>(aArgs)...);\n"}, {"t": "", "n": 127, "l": " \n"}, {"t": "", "n": 128, "l": "   if (type != DisplayItemType::TYPE_GENERIC) {\n"}, {"t": "", "n": 129, "l": "     item->SetType(type);\n"}, {"t": "", "n": 130, "l": "   }\n"}, {"t": "", "n": 131, "l": " \n"}, {"t": "", "n": 132, "l": "   item->SetPerFrameIndex(aIndex);\n"}, {"t": "-", "n": 133, "l": "-  item->SetExtraPageForPageNum(aBuilder->GetBuildingExtraPagesForPageNum());\n"}, {"t": "+", "n": 134, "l": "+  item->SetPageNum(aBuilder->GetBuildingPageNum());\n"}, {"t": "", "n": 135, "l": " \n"}, {"t": "", "n": 136, "l": "   nsPaintedDisplayItem* paintedItem = item->AsPaintedDisplayItem();\n"}, {"t": "", "n": 137, "l": "   if (paintedItem) {\n"}, {"t": "", "n": 138, "l": "     InitializeHitTestInfo(aBuilder, paintedItem, type);\n"}, {"t": "", "n": 139, "l": "   }\n"}, {"t": "", "n": 140, "l": " \n"}, {"t": "", "n": 141, "l": "   if (aBuilder->InInvalidSubtree() ||\n"}, {"t": "", "n": 142, "l": "       item->FrameForInvalidation()->IsFrameModified()) {\n"}, {"t": "@", "n": 143, "l": "@@ -2220,17 +2238,17 @@ class nsDisplayItem {\n"}, {"t": "", "n": 144, "l": "    * Pairing this with the Frame() pointer gives a key that\n"}, {"t": "", "n": 145, "l": "    * uniquely identifies this display item in the display item tree.\n"}, {"t": "", "n": 146, "l": "    */\n"}, {"t": "", "n": 147, "l": "   uint32_t GetPerFrameKey() const {\n"}, {"t": "", "n": 148, "l": "     // The top 8 bits are the page index\n"}, {"t": "", "n": 149, "l": "     // The middle 16 bits of the per frame key uniquely identify the display\n"}, {"t": "", "n": 150, "l": "     // item when there are more than one item of the same type for a frame.\n"}, {"t": "", "n": 151, "l": "     // The low 8 bits are the display item type.\n"}, {"t": "-", "n": 152, "l": "-    return (static_cast<uint32_t>(mExtraPageForPageNum)\n"}, {"t": "+", "n": 153, "l": "+    return (static_cast<uint32_t>(mPageNum)\n"}, {"t": "", "n": 154, "l": "             << (TYPE_BITS + (sizeof(mPerFrameIndex