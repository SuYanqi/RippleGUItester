entContentEvents\";\n"}, {"t": "+", "n": 14, "l": "+\n"}, {"t": "", "n": 15, "l": " export class ScreenshotsComponentChild extends JSWindowActorChild {\n"}, {"t": "", "n": 16, "l": "   #resizeTask;\n"}, {"t": "", "n": 17, "l": "   #scrollTask;\n"}, {"t": "", "n": 18, "l": "   #overlay;\n"}, {"t": "+", "n": 19, "l": "+  #preventableEventsAdded = false;\n"}, {"t": "", "n": 20, "l": " \n"}, {"t": "", "n": 21, "l": "   static OVERLAY_EVENTS = [\n"}, {"t": "", "n": 22, "l": "     \"click\",\n"}, {"t": "", "n": 23, "l": "     \"pointerdown\",\n"}, {"t": "", "n": 24, "l": "     \"pointermove\",\n"}, {"t": "", "n": 25, "l": "     \"pointerup\",\n"}, {"t": "", "n": 26, "l": "     \"keyup\",\n"}, {"t": "", "n": 27, "l": "     \"keydown\",\n"}, {"t": "", "n": 28, "l": "   ];\n"}, {"t": "", "n": 29, "l": " \n"}, {"t": "+", "n": 30, "l": "+  // The following events are only listened to so we can prevent them from\n"}, {"t": "+", "n": 31, "l": "+  // reaching the content page. The events in OVERLAY_EVENTS are also prevented.\n"}, {"t": "+", "n": 32, "l": "+  static PREVENTABLE_EVENTS = [\n"}, {"t": "+", "n": 33, "l": "+    \"mousemove\",\n"}, {"t": "+", "n": 34, "l": "+    \"mousedown\",\n"}, {"t": "+", "n": 35, "l": "+    \"mouseup\",\n"}, {"t": "+", "n": 36, "l": "+    \"touchstart\",\n"}, {"t": "+", "n": 37, "l": "+    \"touchmove\",\n"}, {"t": "+", "n": 38, "l": "+    \"touchend\",\n"}, {"t": "+", "n": 39, "l": "+    \"dblclick\",\n"}, {"t": "+", "n": 40, "l": "+    \"auxclick\",\n"}, {"t": "+", "n": 41, "l": "+    \"keypress\",\n"}, {"t": "+", "n": 42, "l": "+    \"contextmenu\",\n"}, {"t": "+", "n": 43, "l": "+  ];\n"}, {"t": "+", "n": 44, "l": "+\n"}, {"t": "", "n": 45, "l": "   get overlay() {\n"}, {"t": "", "n": 46, "l": "     return this.#overlay;\n"}, {"t": "", "n": 47, "l": "   }\n"}, {"t": "", "n": 48, "l": " \n"}, {"t": "", "n": 49, "l": "   receiveMessage(message) {\n"}, {"t": "", "n": 50, "l": "     switch (message.name) {\n"}, {"t": "", "n": 51, "l": "       case \"Screenshots:ShowOverlay\":\n"}, {"t": "", "n": 52, "l": "         return this.startScreenshotsOverlay();\n"}, {"t": "@", "n": 53, "l": "@@ -57,29 +76,38 @@ export class ScreenshotsComponentChild e\n"}, {"t": "", "n": 54, "l": "     return null;\n"}, {"t": "", "n": 55, "l": "   }\n"}, {"t": "", "n": 56, "l": " \n"}, {"t": "", "n": 57, "l": "   handleEvent(event) {\n"}, {"t": "", "n": 58, "l": "     if (!event.isTrusted) {\n"}, {"t": "", "n": 59, "l": "       return;\n"}, {"t": "", "n": 60, "l": "     }\n"}, {"t": "", "n": 61, "l": " \n"}, {"t": "+", "n": 62, "l": "+    // Handle overlay events here\n"}, {"t": "+", "n": 63, "l": "+    if (\n"}, {"t": "+", "n": 64, "l": "+      ScreenshotsComponentChild.OVERLAY_EVENTS.includes(event.type) ||\n"}, {"t": "+", "n": 65, "l": "+      ScreenshotsComponentChild.PREVENTABLE_EVENTS.includes(event.type)\n"}, {"t": "+", "n": 66, "l": "+    ) {\n"}, {"t": "+", "n": 67, "l": "+      if (!this.overlay?.initialized) {\n"}, {"t": "+", "n": 68, "l": "+        return;\n"}, {"t": "+", "n": 69, "l": "+      }\n"}, {"t": "+", "n": 70, "l": "+\n"}, {"t": "+", "n": 71, "l": "+      // Preventing a pointerdown event throws an error in debug builds.\n"}, {"t": "+", "n": 72, "l": "+      // See https://searchfox.org/mozilla-central/rev/b41bb321fe4bd7d03926083698ac498ebec0accf/widget/WidgetEventImpl.cpp#566-572\n"}, {"t": "+", "n": 73, "l": "+      // Don't prevent the default context menu.\n"}, {"t": "+", "n": 74, "l": "+      if (![\"contextmenu\", \"pointerdown\"].includes(event.type)) {\n"}, {"t": "+", "n": 75, "l": "+        event.preventDefault();\n"}, {"t": "+", "n": 76, "l": "+      }\n"}, {"t": "+", "n": 77, "l": "+\n"}, {"t": "+", "n": 78, "l": "+      event.stopImmediatePropagation();\n"}, {"t": "+", "n": 79, "l": "+      this.overlay.handleEvent(event);\n"}, {"t": "+", "n": 80, "l": "+      return;\n"}, {"t": "+", "n": 81, "l": "+    }\n"}, {"t": "+", "n": 82, "l": "+\n"}, {"t": "", "n": 83, "l": "     switch (event.type) {\n"}, {"t": "-", "n": 84, "l": "-      case \"click\":\n"}, {"t": "-", "n": 85, "l": "-      case \"pointerdown\":\n"}, {"t": "-", "n": 86, "l": "-      case \"pointermove\":\n"}, {"t": "-", "n": 87, "l": "-      case \"pointerup\":\n"}, {"t": "-", "n": 88, "l": "-      case \"keyup\":\n"}, {"t": "-", "n": 89, "l": "-      case \"keydown\":\n"}, {"t": "-", "n": 90, "l": "-      case \"selectionchange\":\n"}, {"t": "-", "n": 91, "l": "-        if (!this.overlay?.initialized) {\n"}, {"t": "-", "n": 92, "l": "-          return;\n"}, {"t": "-", "n": 93, "l": "-        }\n"}, {"t": "-", "n": 94, "l": "-        this.overlay.handleEvent(event);\n"}, {"t": "-", "n": 95, "l": "-        break;\n"}, {"t": "", "n": 96, "l": "       case \"beforeunload\":\n"}, {"t": "", "n": 97, "l": "         this.requestCancelScreenshot(\"navigation\");\n"}, {"t": "", "n": 98, "l": "         break;\n"}, {"t": "", "n": 99, "l": "       case \"resize\":\n"}, {"t": "", "n": 100, "l": "         if (!this.#resizeTask && this.overlay?.initialized) {\n"}, {"t": "", "n": 101, "l": "           this.#resizeTask = new lazy.DeferredTask(() => {\n"}, {"t": "", "n": 102, "l": "             this.overlay.updateScreenshotsOverlayDimensions(\"resize\");\n"}, {"t": "", "n": 103, "l": "           }, 16);\n"}, {"t": "@", "n": 104, "l": "@@ -221,17 +249,26 @@ export class ScreenshotsComponentChild e\n"}, {"t": "", "n": 105, "l": "     this.addOverlayEventListeners();\n"}, {"t": "", "n": 106, "l": "   }\n"}, {"t": "", "n": 107, "l": " \n"}, {"t": "", "n": 108, "l": "   addOverlayEventListeners() {\n"}, {"t": "", "n": 109, "l": "     let chromeEventHandler = this.docShell.chromeEventHandler;\n"}, {"t": "", "n": 110, "l": "     for (let event of ScreenshotsComponentChild.OVERLAY_EVENTS) {\n"}, {"t": "", "n": 111, "l": "       chromeEventHandler.addEventListener(event, this, true);\n"}, {"t": "", "n": 112, "l": "     }\n"}, {"t": "+", "n": 113, "l": "+\n"}, {"t": "", "n": 114, "l": "     this.document.addEventListener(\"selectionchange\", this);\n"}, {"t": "+", "n": 115, "l": "+\n"}, {"t": "+", "n": 116, "l": "+    if (Services.prefs.getBoolPref(SCREENSHOTS_PREVENT_CONTENT_EVENTS_PREF)) {\n"}, {"t": "+", "n": 117, "l": "+      for (let event of ScreenshotsComponentChild.PREVENTABLE_EVENTS) {\n"}, {"t": "+", "n": 118, "l": "+        chromeEventHandler.addEventListener(event, this, true);\n"}, {"t": "+", "n": 119, "l": "+      }\n"}, {"t": "+", "n": 120, "l": "+\n"}, {"t": "+", "n": 121, "l": "+      this.#preventableEventsAdded = true;\n"}, {"t": "+", "n": 122, "l": "+    }\n"}, {"t": "", "n": 123, "l": "   }\n"}, {"t": "", "n": 124, "l": " \n"}, {"t": "", "n": 125, "l": "   /**\n"}, {"t": "", "n": 126, "l": "    * Wait until the document is ready and then show the screenshots overlay\n"}, {"t": "", "n": 127, "l": "    *\n"}, {"t": "", "n": 128, "l": "    * @returns {Boolean} true when document is ready and the overlay is shown\n"}, {"t": "", "n": 129, "l": "    * otherwise false\n"}, {"t": "", "n": 130, "l": "    */\n"}, {"t": "@", "n": 131, "l": "@@ -259,17 +296,26 @@ export class ScreenshotsComponentChild e\n"}, {"t": "", "n": 132, "l": "     this.removeOverlayEventListeners();\n"}, {"t": "", "n": 133, "l": "   }\n"}, {"t": "", "n": 134, "l": " \n"}, {"t": "", "n": 135, "l": "   removeOverlayEventListeners() {\n"}, {"t": "", "n": 136, "l": "     let chromeEventHandler = this.docShell.chromeEventHandler;\n"}, {"t": "", "n": 137, "l": "     for (let event of ScreenshotsComponentChild.OVERLAY_EVENTS) {\n"}, {"t": "", "n": 138, "l": "       chromeEventHandler.removeEventListener(event, this, true);\n"}, {"t": "", "n": 139, "l": "     }\n"}, {"t": "+", "n": 140, "l": "+\n"}, {"t": "", "n": 141, "l": "     this.document.removeEventListener(\"selectionchange\", this);\n"}, {"t": "+", "n": 142, "l": "+\n"}, {"t": "+", "n": 143, "l": "+    if (this.#preventableEventsAdded) {\n"}, {"t": "+", "n": 144, "l": "+      for (let event of ScreenshotsComponentChild.PREVENTABLE_EVENTS) {\n"}, {"t": "+", "n": 145, "l": "+        chromeEventHandler.removeEventListener(event, this, true);\n"}, {"t": "+", "n": 146, "l": "+      }\n"}, {"t": "+", "n": 147, "l": "+    }\n"}, {"t": "+", "n": 148, "l": "+\n"}, {"t": "+", "n": 149, "l": "+    this.#preventableEventsAdded = false;\n"}, {"t": "", "n": 150, "l": "   }\n"}, {"t": "", "n": 151, "l": " \n"}, {"t": "", "n": 152, "l": "   /**\n"}, {"t": "", "n": 153, "l": "    * Removes event listeners and the screenshots overlay.\n"}, {"t": "", "n": 154, "l": "    */\n"}, {"t": "", "n": 155, "l": "   endScreenshotsOverlay(options = {}) {\n"}, {"t": "", "n": 156, "l": "     this.removeEventListeners();\n"}, {"t": "", "n": 157, "l": " \n"}]}, {"blockno": 2, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/app/profile/firefox.js\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/app/profile/firefox.js\n"}, {"t": "@", "n": 3, "l": "@@ -2436,16 +2436,19 @@ pref(\"browser.suppress_first_window_anim\n"}, {"t": "", "n": 4, "l": " pref(\"extensions.screenshots.disabled\", false);\n"}, {"t": "", "n": 5, "l": " \n"}, {"t": "", "n": 6, "l": " // Preference that determines whether Screenshots uses the dedicated browser component\n"}, {"t": "", "n": 7, "l": " pref(\"screenshots.browser.component.enabled\", true);\n"}, {"t": "", "n": 8, "l": " \n"}, {"t": "", "n": 9, "l": " // Preference that determines what button to focus\n"}, {"t": "", "n": 10, "l": " pref(\"screenshots.browser.component.last-saved-method\", \"download\");\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "+", "n": 12, "l": "+// Preference that prevents events from reaching the content page.\n"}, {"t": "+", "n": 13, "l": "+pref(\"screenshots.browser.component.preventContentEvents\", true);\n"}, {"t": "+", "n": 14, "l": "+\n"}, {"t": "", "n": 15, "l": " // DoH Rollout: whether to clear the mode value at shutdown.\n"}, {"t": "", "n": 16, "l": " pref(\"doh-rollout.clearModeOnShutdown\", false);\n"}, {"t": "", "n": 17, "l": " \n"}, {"t": "", "n": 18, "l": " // Normandy client preferences\n"},