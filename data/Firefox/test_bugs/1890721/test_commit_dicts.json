EST_PAGE,\n"}, {"t": "", "n": 9, "l": "     },\n"}, {"t": "", "n": 10, "l": "     async browser => {\n"}, {"t": "", "n": 11, "l": "       await clearAllTelemetryEvents();\n"}, {"t": "-", "n": 12, "l": "-      await SpecialPowers.spawn(browser, [SHORT_TEST_PAGE], url => {\n"}, {"t": "-", "n": 13, "l": "-        let a = content.document.createElement(\"a\");\n"}, {"t": "-", "n": 14, "l": "-        a.id = \"clickMe\";\n"}, {"t": "-", "n": 15, "l": "-        a.href = url;\n"}, {"t": "-", "n": 16, "l": "-        a.textContent = \"Click me to unload page\";\n"}, {"t": "-", "n": 17, "l": "-        content.document.querySelector(\"body\").appendChild(a);\n"}, {"t": "-", "n": 18, "l": "-      });\n"}, {"t": "", "n": 19, "l": " \n"}, {"t": "", "n": 20, "l": "       let helper = new ScreenshotsHelper(browser);\n"}, {"t": "", "n": 21, "l": " \n"}, {"t": "", "n": 22, "l": "       // click toolbar button so panel shows\n"}, {"t": "", "n": 23, "l": "       helper.triggerUIFromToolbar();\n"}, {"t": "", "n": 24, "l": "       await helper.waitForOverlay();\n"}, {"t": "", "n": 25, "l": " \n"}, {"t": "", "n": 26, "l": "       await SpecialPowers.spawn(browser, [], () => {\n"}, {"t": "-", "n": 27, "l": "-        content.document.querySelector(\"#clickMe\").click();\n"}, {"t": "+", "n": 28, "l": "+        content.location.reload();\n"}, {"t": "", "n": 29, "l": "       });\n"}, {"t": "", "n": 30, "l": " \n"}, {"t": "", "n": 31, "l": "       await helper.waitForOverlayClosed();\n"}, {"t": "", "n": 32, "l": " \n"}, {"t": "", "n": 33, "l": "       await assertScreenshotsEvents(SCREENSHOTS_EVENTS);\n"}, {"t": "", "n": 34, "l": "     }\n"}, {"t": "", "n": 35, "l": "   );\n"}, {"t": "", "n": 36, "l": " });\n"}]}, {"blockno": 5, "lines": [{"t": "", "n": 1, "l": "new file mode 100644\n"}, {"t": "-", "n": 2, "l": "--- /dev/null\n"}, {"t": "+", "n": 3, "l": "+++ b/browser/components/screenshots/tests/browser/browser_test_prevent_events.js\n"}, {"t": "@", "n": 4, "l": "@@ -0,0 +1,84 @@\n"}, {"t": "+", "n": 5, "l": "+/* Any copyright is dedicated to the Public Domain.\n"}, {"t": "+", "n": 6, "l": "+   https://creativecommons.org/publicdomain/zero/1.0/ */\n"}, {"t": "+", "n": 7, "l": "+\n"}, {"t": "+", "n": 8, "l": "+\"use strict\";\n"}, {"t": "+", "n": 9, "l": "+\n"}, {"t": "+", "n": 10, "l": "+add_task(async function test_events_prevented() {\n"}, {"t": "+", "n": 11, "l": "+  await BrowserTestUtils.withNewTab(\n"}, {"t": "+", "n": 12, "l": "+    {\n"}, {"t": "+", "n": 13, "l": "+      gBrowser,\n"}, {"t": "+", "n": 14, "l": "+      url: SHORT_TEST_PAGE,\n"}, {"t": "+", "n": 15, "l": "+    },\n"}, {"t": "+", "n": 16, "l": "+    async browser => {\n"}, {"t": "+", "n": 17, "l": "+      let helper = new ScreenshotsHelper(browser);\n"}, {"t": "+", "n": 18, "l": "+\n"}, {"t": "+", "n": 19, "l": "+      await ContentTask.spawn(browser, null, async () => {\n"}, {"t": "+", "n": 20, "l": "+        let { ScreenshotsComponentChild } = ChromeUtils.importESModule(\n"}, {"t": "+", "n": 21, "l": "+          \"resource:///actors/ScreenshotsComponentChild.sys.mjs\"\n"}, {"t": "+", "n": 22, "l": "+        );\n"}, {"t": "+", "n": 23, "l": "+        let allOverlayEvents = ScreenshotsComponentChild.OVERLAY_EVENTS.concat(\n"}, {"t": "+", "n": 24, "l": "+          ScreenshotsComponentChild.PREVENTABLE_EVENTS\n"}, {"t": "+", "n": 25, "l": "+        );\n"}, {"t": "+", "n": 26, "l": "+\n"}, {"t": "+", "n": 27, "l": "+        content.eventsReceived = [];\n"}, {"t": "+", "n": 28, "l": "+\n"}, {"t": "+", "n": 29, "l": "+        function eventListener(event) {\n"}, {"t": "+", "n": 30, "l": "+          content.window.eventsReceived.push(event.type);\n"}, {"t": "+", "n": 31, "l": "+        }\n"}, {"t": "+", "n": 32, "l": "+\n"}, {"t": "+", "n": 33, "l": "+        for (let eventName of [...allOverlayEvents, \"wheel\"]) {\n"}, {"t": "+", "n": 34, "l": "+          content.addEventListener(eventName, eventListener, true);\n"}, {"t": "+", "n": 35, "l": "+        }\n"}, {"t": "+", "n": 36, "l": "+      });\n"}, {"t": "+", "n": 37, "l": "+\n"}, {"t": "+", "n": 38, "l": "+      helper.triggerUIFromToolbar();\n"}, {"t": "+", "n": 39, "l": "+      await helper.waitForOverlay();\n"}, {"t": "+", "n": 40, "l": "+\n"}, {"t": "+", "n": 41, "l": "+      // key events\n"}, {"t": "+", "n": 42, "l": "+      await key.down(\"s\");\n"}, {"t": "+", "n": 43, "l": "+      await key.up(\"s\");\n"}, {"t": "+", "n": 44, "l": "+      await key.press(\"s\");\n"}, {"t": "+", "n": 45, "l": "+\n"}, {"t": "+", "n": 46, "l": "+      // touch events\n"}, {"t": "+", "n": 47, "l": "+      await touch.start(10, 10);\n"}, {"t": "+", "n": 48, "l": "+      await touch.move(20, 20);\n"}, {"t": "+", "n": 49, "l": "+      await touch.end(20, 20);\n"}, {"t": "+", "n": 50, "l": "+\n"}, {"t": "+", "n": 51, "l": "+      // pointermove/mousemove, pointerdown/mousedown, pointerup/mouseup events\n"}, {"t": "+", "n": 52, "l": "+      await helper.clickTestPageElement();\n"}, {"t": "+", "n": 53, "l": "+\n"}, {"t": "+", "n": 54, "l": "+      // click events and contextmenu\n"}, {"t": "+", "n": 55, "l": "+      await mouse.dblclick(100, 100);\n"}, {"t": "+", "n": 56, "l": "+      await mouse.auxclick(100, 100, { button: 1 });\n"}, {"t": "+", "n": 57, "l": "+      await mouse.click(100, 100);\n"}, {"t": "+", "n": 58, "l": "+      await mouse.contextmenu(100, 100);\n"}, {"t": "+", "n": 59, "l": "+\n"}, {"t": "+", "n": 60, "l": "+      let wheelEventPromise = helper.waitForContentEventOnce(\"wheel\");\n"}, {"t": "+", "n": 61, "l": "+      await ContentTask.spawn(browser, null, () => {\n"}, {"t": "+", "n": 62, "l": "+        content.dispatchEvent(new content.WheelEvent(\"wheel\"));\n"}, {"t": "+", "n": 63, "l": "+      });\n"}, {"t": "+", "n": 64, "l": "+      await wheelEventPromise;\n"}, {"t": "+", "n": 65, "l": "+\n"}, {"t": "+", "n": 66, "l": "+      let contentEventsReceived = await ContentTask.spawn(\n"}, {"t": "+", "n": 67, "l": "+        browser,\n"}, {"t": "+", "n": 68, "l": "+        null,\n"}, {"t": 