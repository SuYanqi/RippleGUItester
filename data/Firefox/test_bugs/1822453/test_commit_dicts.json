[{"node": "b68ba468c8215e516b1a0f00509bd70c857fd518", "date": [1679330350.0, 0], "desc": "Bug 1822453 - Tweak settings dialog list styles. r=settings-reviewers,mconley\n\nThis is not a new regression: that min-height which effectively prevents\nshrinking of this list has been there since ~forever, so probably this\nbroke, if it broke at all, when we enabled modern flexbox emulation of\nthese dialogs.\n\nNow that XUL can shrink this gets us the behavior we want (default to\n18em, but allow both growing and shrinking).\n\nFix the sites list as well to behave similarly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D173034", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Emilio Cobos \u00c1lvarez <emilio@crisal.io>", "parents": ["c3037ba20d8b6200b240e4025a86855b74741a52"], "children": ["6f9459cec3048736fa954083b9af0f4c20784764"], "files": [{"file": "browser/components/preferences/dialogs/permissions.xhtml", "status": "modified"}, {"file": "browser/components/preferences/dialogs/siteDataSettings.xhtml", "status": "modified"}, {"file": "browser/components/preferences/dialogs/sitePermissions.css", "status": "modified"}, {"file": "browser/themes/shared/preferences/siteDataSettings.css", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/components/preferences/dialogs/permissions.xhtml\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/components/preferences/dialogs/permissions.xhtml\n"}, {"t": "@", "n": 3, "l": "@@ -61,17 +61,17 @@\n"}, {"t": "", "n": 4, "l": "     <separator class=\"thin\"/>\n"}, {"t": "", "n": 5, "l": "     <listheader>\n"}, {"t": "", "n": 6, "l": "       <treecol id=\"siteCol\" data-l10n-id=\"permissions-site-name\" style=\"flex: 3 3 auto; width: 0\"\n"}, {"t": "", "n": 7, "l": "                onclick=\"gPermissionManager.buildPermissionsList(event.target)\"/>\n"}, {"t": "", "n": 8, "l": "       <treecol id=\"statusCol\" data-l10n-id=\"permissions-status\" style=\"flex: 1 1 auto; width: 0\"\n"}, {"t": "", "n": 9, "l": "                data-isCurrentSortCol=\"true\"\n"}, {"t": "", "n": 10, "l": "                onclick=\"gPermissionManager.buildPermissionsList(event.target);\"/>\n"}, {"t": "", "n": 11, "l": "     </listheader>\n"}, {"t": "-", "n": 12, "l": "-    <richlistbox id=\"permissionsBox\" flex=\"1\" selected=\"false\"\n"}, {"t": "+", "n": 13, "l": "+    <richlistbox id=\"permissionsBox\" selected=\"false\"\n"}, {"t": "", "n": 14, "l": "                  onkeypress=\"gPermissionManager.onPermissionKeyPress(event);\"\n"}, {"t": "", "n": 15, "l": "                  onselect=\"gPermissionManager.onPermissionSelect();\"/>\n"}, {"t": "", "n": 16, "l": "   </vbox>\n"}, {"t": "", "n": 17, "l": " \n"}, {"t": "", "n": 18, "l": "   <hbox class=\"actionButtons\">\n"}, {"t": "", "n": 19, "l": "     <button id=\"removePermission\" disabled=\"true\"\n"}, {"t": "", "n": 20, "l": "             data-l10n-id=\"permissions-remove\"\n"}, {"t": "", "n": 21, "l": "             oncommand=\"gPermissionManager.onPermissionDelete();\"/>\n"}]}, {"blockno": 2, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/components/preferences/dialogs/siteDataSettings.xhtml\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/components/preferences/dialogs/siteDataSettings.xhtml\n"}, {"t": "@", "n": 3, "l": "@@ -43,17 +43,17 @@\n"}, {"t": "", "n": 4, "l": " \n"}, {"t": "", "n": 5, "l": "     <listheader>\n"}, {"t": "", "n": 6, "l": "       <treecol style=\"flex: 4 4 auto; width: 50px\" data-l10n-id=\"site-data-column-host\" id=\"hostCol\"/>\n"}, {"t": "", "n": 7, "l": "       <treecol style=\"flex: 1 auto; width: 50px\" data-l10n-id=\"site-data-column-cookies\" id=\"cookiesCol\"/>\n"}, {"t": "", "n": 8, "l": "       <!-- Sorted by usage so the user can quickly see which sites use the most data. -->\n"}, {"t": "", "n": 9, "l": "       <treecol style=\"flex: 2 2 auto; width: 50px\" data-l10n-id=\"site-data-column-storage\" id=\"usageCol\" data-isCurrentSortCol=\"true\"/>\n"}, {"t": "", "n": 10, "l": "       <treecol style=\"flex: 2 2 auto; width: 50px\" data-l10n-id=\"site-data-column-last-used\" id=\"lastAccessedCol\" />\n"}, {"t": "", "n": 11, "l": "     </listheader>\n"}, {"t": "-", "n": 12, "l": "-    <richlistbox seltype=\"multiple\" id=\"sitesList\" orient=\"vertical\" flex=\"1\"/>\n"}, {"t": "+", "n": 13, "l": "+    <richlistbox seltype=\"multiple\" id=\"sitesList\" orient=\"vertical\"/>\n"}, {"t": "", "n": 14, "l": "   </vbox>\n"}, {"t": "", "n": 15, "l": " \n"}, {"t": "", "n": 16, "l": "   <hbox align=\"start\">\n"}, {"t": "", "n": 17, "l": "     <button id=\"removeSelected\" data-l10n-id=\"site-data-remove-selected\"/>\n"}, {"t": "", "n": 18, "l": "     <button id=\"removeAll\"/>\n"}, {"t": "", "n": 19, "l": "   </hbox>\n"}, {"t": "", "n": 20, "l": "   </dialog>\n"}, {"t": "", "n": 21, "l": " </window>\n"}]}, {"blockno": 3, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/components/preferences/dialogs/sitePermissions.css\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/components/preferences/dialogs/sitePermissions.css\n"}, {"t": "@", "n": 3, "l": "@@ -5,18 +5,18 @@\n"}, {"t": "", "n": 4, "l": " .website-name,\n"}, {"t": "", "n": 5, "l": " hbox.website-status {\n"}, {"t": "", "n": 6, "l": "   overflow: hidden; /* Allows equal sizing combined with width=\"0\" */\n"}, {"t": "", "n": 7, "l": "   padding-inline-start: 7px;\n"}, {"t": "", "n": 8, "l": "   align-items: center;\n"}, {"t": "", "n": 9, "l": " }\n"}, {"t": "", "n": 10, "l": " \n"}, {"t": "", "n": 11, "l": " #permissionsBox {\n"}, {"t": "-", "n": 12, "l": "-  min-height: 18em;\n"}, {"t": "-", "n": 13, "l": "-  contain: size;\n"}, {"t": "+", "n": 14, "l": "+  flex: 1 auto;\n"}, {"t": "+", "n": 15, "l": "+  height: 18em;\n"}, {"t": "", "n": 16, "l": " }\n"}, {"t": "", "n": 17, "l": " \n"}, {"t": "", "n": 18, "l": " #siteCol,\n"}, {"t": "", "n": 19, "l": " #statusCol,\n"}, {"t": "", "n": 20, "l": " #permissionsBox > richlistitem {\n"}, {"t": "", "n": 21, "l": "   min-height: 35px;\n"}, {"t": "", "n": 22, "l": " }\n"}, {"t": "", "n": 23, "l": " \n"}]}, {"blockno": 4, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/themes/shared/preferences/siteDataSettings.css\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/themes/shared/preferences/siteDataSettings.css\n"}, {"t": "@", "n": 3, "l": "@@ -1,16 +1,17 @@\n"}, {"t": "", "n": 4, "l": " /* This Source Code Form is subject to the terms of the Mozilla Public\n"}, {"t": "", "n": 5, "l": "  * License, v. 2.0. If a copy of the MPL was not distributed with this\n"}, {"t": "", "n": 6, "l": "  * file, You can obtain one at http://mozilla.org/MPL/2.0/. */\n"}, {"t": "", "n": 7, "l": " \n"}, {"t": "", "n": 8, "l": " /**\n"}, {"t": "", "n": 9, "l": "  * Site Data - Settings dialog\n"}, {"t": "", "n": 10, "l": "  */\n"}, {"t": "", "n": 11, "l": " #sitesList {\n"}, {"t": "+", "n": 12, "l": "+  flex: 1 auto;\n"}, {"t": "", "n": 13, "l": "   height: 20em;\n"}, {"t": "", "n": 14, "l": " }\n"}, {"t": "", "n": 15, "l": " \n"}, {"t": "", "n": 16, "l": " /* Show selected items in high contrast mode. */\n"}, {"t": "", "n": 17, "l": " #sitesList > richlistitem[selected] {\n"}, {"t": "", "n": 18, "l": "   outline: 1px solid transparent;\n"}, {"t": "", "n": 19, "l": " }\n"}, {"t": "", "n": 20, "l": " \n"}]}], "phase": "public", "pushid": 40721, "pushdate": [1679348777, 0], "pushuser": "mlaza@mozilla.com", "landingsystem": "lando", "git_commit": null}]