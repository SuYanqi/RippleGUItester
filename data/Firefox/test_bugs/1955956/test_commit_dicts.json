[{"node": "a504be51755aa3a829fb806a24149e0d8e33ae88", "date": [1742901327.0, 0], "desc": "Bug 1955956 - Reduce arrowpanel padding on small screen sizes when not using touch density. r=desktop-theme-reviewers,dao\n\nIn order to decrease the chances of needing vertical scrollbars on\nthings like the app menu.\n\nThe app menu takes ~800px, so I chose that plus some slack for toolbars\nand so on.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D242705", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Emilio Cobos \u00c1lvarez <emilio@crisal.io>", "parents": ["bb30f7912887d2597833f5711e55220aeda9c90b"], "children": ["d50b0d4c7302a064752090ed463a9aeb42c11383"], "files": [{"file": "browser/themes/shared/customizableui/panelUI-shared.css", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/themes/shared/customizableui/panelUI-shared.css\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/themes/shared/customizableui/panelUI-shared.css\n"}, {"t": "@", "n": 3, "l": "@@ -15,16 +15,21 @@\n"}, {"t": "", "n": 4, "l": "   --menu-panel-width: 22.35em;\n"}, {"t": "", "n": 5, "l": "   --menu-panel-width-wide: 29em;\n"}, {"t": "", "n": 6, "l": " \n"}, {"t": "", "n": 7, "l": "   --arrowpanel-menuitem-margin-block: 0;\n"}, {"t": "", "n": 8, "l": "   --arrowpanel-menuitem-margin-inline: 8px;\n"}, {"t": "", "n": 9, "l": "   --arrowpanel-menuitem-margin: var(--arrowpanel-menuitem-margin-block) var(--arrowpanel-menuitem-margin-inline);\n"}, {"t": "", "n": 10, "l": "   --arrowpanel-menuitem-padding-block: 8px;\n"}, {"t": "", "n": 11, "l": "   --arrowpanel-menuitem-padding-inline: 8px;\n"}, {"t": "+", "n": 12, "l": "+  @media (device-height < 1100px) {\n"}, {"t": "+", "n": 13, "l": "+    &:not([uidensity=touch]) {\n"}, {"t": "+", "n": 14, "l": "+      --arrowpanel-menuitem-padding-block: 4px;\n"}, {"t": "+", "n": 15, "l": "+    }\n"}, {"t": "+", "n": 16, "l": "+  }\n"}, {"t": "", "n": 17, "l": "   --arrowpanel-menuitem-padding: var(--arrowpanel-menuitem-padding-block) var(--arrowpanel-menuitem-padding-inline);\n"}, {"t": "", "n": 18, "l": "   --arrowpanel-menuitem-border-radius: 4px;\n"}, {"t": "", "n": 19, "l": "   --arrowpanel-header-info-icon-padding: 4px;\n"}, {"t": "", "n": 20, "l": "   --arrowpanel-header-info-icon-full-width: calc(16px + (2 * var(--arrowpanel-header-info-icon-padding)));\n"}, {"t": "", "n": 21, "l": "   --panel-separator-margin-vertical: 4px;\n"}, {"t": "", "n": 22, "l": "   --panel-separator-margin-horizontal: 8px;\n"}, {"t": "", "n": 23, "l": "   --panel-separator-margin: var(--panel-separator-margin-vertical) var(--panel-separator-margin-horizontal);\n"}, {"t": "", "n": 24, "l": "   --panel-subview-body-padding-block: 8px;\n"}]}], "phase": "public", "pushid": 42662, "pushdate": [1742980403, 0], "pushuser": "abutkovits@mozilla.com", "landingsystem": "lando", "git_commit": null}, {"node": "ea1f8ee852a8bf60d20b7cab9795db7d9bf50117", "date": [1743091109.0, -7200], "desc": "Backed out changeset a504be51755a (bug 1955956) for affecting various macOS configurations by default.", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Stanca Serban <sstanca@mozilla.com>", "parents": ["5ba25ce5ef4add4c45e4b997f2c3043c9aa04938"], "children": ["7c6a1b577983f04766c425ea6f98966655f969c7"], "files": [{"file": "browser/themes/shared/customizableui/panelUI-shared.css", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/themes/shared/customizableui/panelUI-shared.css\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/themes/shared/customizableui/panelUI-shared.css\n"}, {"t": "@", "n": 3, "l": "@@ -15,21 +15,16 @@\n"}, {"t": "", "n": 4, "l": "   --menu-panel-width: 22.35em;\n"}, {"t": "", "n": 5, "l": "   --menu-panel-width-wide: 29em;\n"}, {"t": "", "n": 6, "l": " \n"}, {"t": "", "n": 7, "l": "   --arrowpanel-menuitem-margin-block: 0;\n"}, {"t": "", "n": 8, "l": "   --arrowpanel-menuitem-margin-inl