[{"node": "e1ea954c14326b950d4f344e3fe367dfe4aa67dd", "date": [1718290552.0, 0], "desc": "Bug 1896128 - Pressing Home on trimmed urlbar value should put cursor at 0. r=jteow\n\nDifferential Revision: https://phabricator.services.mozilla.com/D212790", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Marco Bonardo <mbonardo@mozilla.com>", "parents": ["8bab962f00f9cb1dda62857f14588068e1b01e5e"], "children": ["fd0489f4597242a261be5bdef5b3ebb743b0d419"], "files": [{"file": "browser/components/urlbar/UrlbarInput.sys.mjs", "status": "modified"}, {"file": "browser/components/urlbar/tests/browser/browser_less_common_selection_manipulations.js", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/components/urlbar/UrlbarInput.sys.mjs\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/components/urlbar/UrlbarInput.sys.mjs\n"}, {"t": "@", "n": 3, "l": "@@ -3187,18 +3187,23 @@ export class UrlbarInput {\n"}, {"t": "", "n": 4, "l": "       return false;\n"}, {"t": "", "n": 5, "l": "     }\n"}, {"t": "", "n": 6, "l": " \n"}, {"t": "", "n": 7, "l": "     return true;\n"}, {"t": "", "n": 8, "l": "   }\n"}, {"t": "", "n": 9, "l": " \n"}, {"t": "", "n": 10, "l": "   /**\n"}, {"t": "", "n": 11, "l": "    * Restores the untrimmed value in the urlbar.\n"}, {"t": "+", "n": 12, "l": "+   *\n"}, {"t": "+", "n": 13, "l": "+   * @param {object} [options]\n"}, {"t": "+", "n": 14, "l": "+   *  Options for untrimming.\n"}, {"t": "+", "n": 15, "l": "+   * @param {boolean} [options.moveCursorToStart]\n"}, {"t": "+", "n": 16, "l": "+   *  Whether the cursor should be moved at position 0 after untrimming.\n"}, {"t": "", "n": 17, "l": "    */\n"}, {"t": "-", "n": 18, "l": "-  #maybeUntrimUrl() {\n"}, {"t": "+", "n": 19, "l": "+  #maybeUntrimUrl({ moveCursorToStart = false } = {}) {\n"}, {"t": "", "n": 20, "l": "     // Check if we can untrim the current value.\n"}, {"t": "", "n": 21, "l": "     if (\n"}, {"t": "", "n": 22, "l": "       !lazy.UrlbarPrefs.get(\"untrimOnUserInteraction.featureGate\") ||\n"}, {"t": "", "n": 23, "l": "       !this._protocolIsTrimmed ||\n"}, {"t": "", "n": 24, "l": "       !this.focused ||\n"}, {"t": "", "n": 25, "l": "       this.#allTextSelected\n"}, {"t": "", "n": 26, "l": "     ) {\n"}, {"t": "", "n": 27, "l": "       return;\n"}, {"t": "@", "n": 28, "l": "@@ -3211,16 +3216,24 @@ export class UrlbarInput {\n"}, {"t": "", "n": 29, "l": "     let offset = lazy.BrowserUIUtils.trimURLProtocol.length;\n"}, {"t": "", "n": 30, "l": " \n"}, {"t": "", "n": 31, "l": "     // In case of autofill, we may have to adjust its boundaries.\n"}, {"t": "", "n": 32, "l": "     if (this._autofillPlaceholder) {\n"}, {"t": "", "n": 33, "l": "       this._autofillPlaceholder.selectionStart += offset;\n"}, {"t": "", "n": 34, "l": "       this._autofillPlaceholder.selectionEnd += offset;\n"}, {"t": "", "n": 35, "l": "     }\n"}, {"t": "", "n": 36, "l": " \n"}, {"t": "+", "n": 37, "l": "+    if (moveCursorToStart) {\n"}, {"t": "+", "n": 38, "l": "+      this._setValue(this._untrimmedValue, {\n"}, {"t": "+", "n": 39, "l": "+        valueIsTyped: this.valueIsTyped,\n"}, {"t": "+", "n": 40, "l": "+      });\n"}, {"t": "+", "n": 41, "l": "+      this.setSelectionRange(0, 0);\n"}, {"t": "+", "n": 42, "l": "+      return;\n"}, {"t": "+", "n": 43, "l": "+    }\n"}, {"t": "+", "n": 44, "l": "+\n"}, {"t": "", "n": 45, "l": "     if (selectionStart == selectionEnd) {\n"}, {"t": "", "n": 46, "l": "       // When cursor is at the end of the string, untrimming may\n"}, {"t": "", "n": 47, "l": "       // reintroduced a trailing slash and we want to move past it.\n"}, {"t": "", "n": 48, "l": "       if (selectionEnd == this.value.length) {\n"}, {"t": "", "n": 49, "l": "         offset += 1;\n"}, {"t": "", "n": 50, "l": "       }\n"}, {"t": "", "n": 51, "l": "       selectionStart = selectionEnd += offset;\n"}, {"t": "", "n": 52, "l": "     } else {\n"}, {"t": "@", "n": 53, "l": "@@ -4106,16 +4119,18 @@ export class UrlbarInput {\n"}, {"t": "", "n": 54, "l": "     if (event.data && this._keyDownEnterDeferred) {\n"}, {"t": "", "n": 55, "l": "       // Ignore char key input while processing enter key.\n"}, {"t": "", "n": 56, "l": "       event.preventDefault();\n"}, {"t": "", "n": 57, "l": "     }\n"}, {"t": "", "n": 58, "l": "   }\n"}, {"t": "", "n": 59, "l": " \n"}, {"t": "", "n": 60, "l": "   _on_keydown(event) {\n"}, {"t": "", "n": 61, "l": "     this.#allTextSelectedOnKeyDown = this.#allTextSelected;\n"}, {"t": "+", "n": 62, "l": "+    this._isKeyDownWithMetaAndLeft =\n"}, {"t": "+", "n": 63, "l": "+      event.keyCode == KeyEvent.DOM_VK_LEFT && event.metaKey;\n"}, {"t": "", "n": 64, "l": "     if (event.keyCode === KeyEvent.DOM_VK_RETURN) {\n"}, {"t": "", "n": 65, "l": "       if (this._keyDownEnterDeferred) {\n"}, {"t": "", "n": 66, "l": "         this._keyDownEnterDeferred.reject();\n"}, {"t": "", "n": 67, "l": "       }\n"}, {"t": "", "n": 68, "l": "       this._keyDownEnterDeferred = Promise.withResolvers();\n"}, {"t": "", "n": 69, "l": "       event._disableCanonization = this._isKeyDownWithCtrl;\n"}, {"t": "", "n": 70, "l": "     } else if (event.keyCode !== KeyEvent.DOM_VK_CONTROL && event.ctrlKey) {\n"}, {"t": "", "n": 71, "l": "       this._isKeyDownWithCtrl = true;\n"}, {"t": "@", "n": 72, "l": "@@ -4134,17 +4149,27 @@ export class UrlbarInput {\n"}, {"t": "", "n": 73, "l": "     this._toggleActionOverride(event);\n"}, {"t": "", "n": 74, "l": "     this.eventBufferer.maybeDeferEvent(event, () => {\n"}, {"t": "", "n": 75, "l": "       this.controller.handleKeyNavigation(event);\n"}, {"t": "", "n": 76, "l": "     });\n"}, {"t": "", "n": 77, "l": "   }\n"}, {"t": "", "n": 78, "l": " \n"}, {"t": "", "n": 79, "l": "   async _on_keyup(event) {\n"}, {"t": "", "n": 80, "l": "     if (this.#allTextSelectedOnKeyDown) {\n"}, {"t": "-", "n": 81, "l": "-      this.#maybeUntrimUrl();\n"}, {"t": "+", "n": 82, "l": "+      let moveCursorToStart = this.#isHomeKeyUpEvent(event);\n"}, {"t": "+", "n": 83, "l": "+      // We must set the selection immediately because:\n"}, {"t": "+", "n": 84, "l": "+      //  - on Mac Fn + Left is not handled properly as Home\n"}, {"t": "+", "n": 85, "l": "+      //  - untrim depends on text not being fully selected.\n"}, {"t": "+", "n": 86, "l": "+      if (moveCursorToStart) {\n"}, {"t": "+", "n": 87, "l": "+        this.selectionStart = this.selectionEnd = 0;\n"}, {"t": "+", "n": 88, "l": "+      }\n"}, {"t": "+", "n": 89, "l": "+      this.#maybeUntrimUrl({ moveCursorToStart });\n"}, {"t": "+", "n": 90, "l": "+    }\n"}, {"t": "+", "n": 91, "l": "+    if (event.keyCode === KeyEvent.DOM_VK_META) {\n"}, {"t": "+", "n": 92, "l": "+      this._isKeyDownWithMetaAndLeft = false;\n"}, {"t": "", "n": 93, "l": "     }\n"}, {"t": "", "n": 94, "l": "     if (event.keyCode === KeyEvent.DOM_VK_CONTROL) {\n"}, {"t": "", "n": 95, "l": "       this._isKeyDownWithCtrl = false;\n"}, {"t": "", "n": 96, "l": "     }\n"}, {"t": "", "n": 97, "l": " \n"}, {"t": "", "n": 98, "l": "     this._toggleActionOverride(event);\n"}, {"t": "", "n": 99, "l": " \n"}, {"t": "", "n": 100, "l": "     // Pressing Enter key while pressing Meta key, and next, even when releasing\n"}, {"t": "@", "n": 101, "l": "@@ -4355,16 +4380,42 @@ export class UrlbarInput {\n"}, {"t": "", "n": 102, "l": "   get #selectedText() {\n"}, {"t": "", "n": 103, "l": "     return this.editor.selection.toStringWithFormat(\n"}, {"t": "", "n": 104, "l": "       \"text/plain\",\n"}, {"t": "", "n": 105, "l": "       Ci.nsIDocumentEncoder.OutputPreformatted |\n"}, {"t": "", "n": 106, "l": "         Ci.nsIDocumentEncoder.OutputRaw,\n"}, {"t": "", "n": 107, "l": "       0\n"}, {"t": "", "n": 108, "l": "     );\n"}, {"t": "", "n": 109, "l": "   }\n"}, {"t": "+", "n": 110, "l": "+\n"}, {"t": "+", "n": 111, "l": "+  /**\n"}, {"t": "+", "n": 112, "l": "+   * Check whether a key event has a similar effect as the Home key.\n"}, {"t": "+", "n": 113, "l": "+   *\n"}, {"t": "+", "n": 114, "l": "+   * @param {nsIEvent} event A Keyboard event\n"}, {"t": "+", "n": 115, "l": "+   * @returns {boolean} Whether the even will act like the Home key.\n"}, {"t": "+", "n": 116, "l": "+   */\n"}, {"t": "+", "n": 117, "l": "+  #isHomeKeyUpEvent(event) {\n"}, {"t": "+", "n": 118, "l": "+    let isMac = AppConstants.platform === \"macosx\";\n"}, {"t": "+", "n": 119, "l": "+    return (\n"}, {"t": "+", "n": 120, "l": "+      // On MacOS this can be generated with Fn + Left.\n"}, {"t": "+", "n": 121, "l": "+      event.keyCode == KeyEvent.DOM_VK_HOME ||\n"}, {"t": "+", "n": 122, "l": "+      // Windows and Linux also support Ctrl + Left.\n"}, {"t": "+", "n": 123, "l": "+      (!isMac && event.keyCode == KeyboardEvent.DOM_VK_LEFT && event.ctrlKey) ||\n"}, {"t": "+", "n": 124, "l": "+      // MacOS supports other combos to move cursor at the start of the line.\n"}, {"t": "+", "n": 125, "l": "+      // For example Ctrl + A.\n"}, {"t": "+", "n": 126, "l": "+      (isMac && event.keyCode == KeyboardEvent.DOM_VK_A && event.ctrlKey) ||\n"}, {"t": "+", "n": 127, "l": "+      // And also Cmd (Meta) + Left.\n"}, {"t": "+", "n": 128, "l": "+      // Unfortunately on MacOS it's not possible to detect combos with the meta\n"}, {"t": "+", "n": 129, "l": "+      // key during the keyup event, due to how the OS handles events. Thus we\n"}, {"t": "+", "n": 130, "l": "+      // record the combo on keydown, and check for it here.\n"}, {"t": "+", "n": 131, "l": "+      (isMac &&\n"}, {"t": "+", "n": 132, "l": "+        event.keyCode == KeyEvent.DOM_VK_META &&\n"}, {"t": "+", "n": 133, "l": "+        this._isKeyDownWithMetaAndLeft)\n"}, {"t": "+", "n": 134, "l": "+    );\n"}, {"t": "+", "n": 135, "l": "+  }\n"}, {"t": "", "n": 136, "l": " }\n"}, {"t": "", "n": 137, "l": " \n"}, {"t": "", "n": 138, "l": " /**\n"}, {"t": "", "n": 139, "l": "  * Tries to extract droppable data from a DND event.\n"}, {"t": "", "n": 140, "l": "  *\n"}, {"t": "", "n": 141, "l": "  * @param {Event} event The DND event to examine.\n"}, {"t": "", "n": 142, "l": "  * @returns {URL|string|null}\n"}, {"t": "", "n": 143, "l": "  *          null if there's a security reason for which we should do nothing.\n"}]}, {"blockno": 2, "lines": [{"t": "-", "n": 1, "l": "--- a/browser/components/urlbar/tests/browser/browser_less_common_selection_manipulations.js\n"}, {"t": "+", "n": 2, "l": "+++ b/browser/components/urlbar/tests/browser/browser_less_common_selection_manipulations.js\n"}, {"t": "@", "n": 3, "l": "@@ -25,28 +25,65 @@ const tests = [\n"}, {"t": "", "n": 4, "l": "     description: \"Test HOME starting from full selection\",\n"}, {"t": "", "n": 5, "l": "     openPanel() {\n"}, {"t": "", "n": 6, "l": "       EventUtils.synthesizeKey(\"l\", { accelKey: true });\n"}, {"t": "", "n": 7, "l": "     },\n"}, {"t": "", "n": 8, "l": "     get selection() {\n"}, {"t": "", "n": 9, "l": "       return [0, gURLBar.value.length];\n"}, {"t": "", "n": 10, "l": "     },\n"}, {"t": "", "n": 11, "l": "     manipulate() {\n"}, {"t": "-", "n": 12, "l": "-      // Cursor must move to the first visible character, regardless of any\n"}, {"t": "-", "n": 13, "l": "-      // \"untrimming\" we could be doing.\n"}, {"t": "-", "n": 14, "l": "-      this._visibleValue = gURLBar.value;\n"}, {"t": "+", "n": 15, "l": "+      EventUtils.synthesizeKey(\"KEY_Home\");\n"}, {"t": "+", "n": 16, "l": "+    },\n"}, {"t": "+", "n": 17, "l": "+    get modifiedSelection() {\n"}, {"t": "+", "n": 18, "l": "+      // Cursor must move to zero, regardless of any untrimming.\n"}, {"t": "+", "n": 19, "l": "+      return [0, 0];\n"}, {"t": "+", "n": 20, "l": "+    },\n"}, {"t": "+", "n": 21, "l": "+  },\n"}, {"t": "+", "n": 22, "l": "+  {\n"}, {"t": "+", "n": 23, "l": "+    description: \"Test CTRL/META LEFT starting from full selection\",\n"}, {"t": "+", "n": 24, "l": "+    openPanel() {\n"}, {"t": "+", "n": 25, "l": "+      EventUtils.synthesizeKey(\"l\", { accelKey: true });\n"}, {"t": "+", "n": 26, "l": "+    },\n"}, {"t": "+", "n": 27, "l": "+    get selection() {\n"}, {"t": "+", "n": 28, "l": "+      return [0, gURLBar.value.length];\n"}, {"t": "+", "n": 29, "l": "+    },\n"}, {"t": "+", "n": 30, "l": "+    manipulate() {\n"}, {"t": "", "n": 31, "l": "       if (AppConstants.platform == \"macosx\") {\n"}, {"t": "-", "n": 32, "l": "-        EventUtils.synthesizeKey(\"KEY_ArrowLeft\", { metaKey: true });\n"}, {"t": "+", "n": 33, "l": "+        // Synthesized key events work differently from native ones, here\n"}, {"t": "+", "n": 34, "l": "+        // we simulate the native behavior.\n"}, {"t": "+", "n": 35, "l": "+        EventUtils.synthesizeKey(\"KEY_ArrowLeft\", {\n"}, {"t": "+", "n": 36, "l": "+          type: \"keydown\",\n"}, {"t": "+", "n": 37, "l": "+          metaKey: true,\n"}, {"t": "+", "n": 38, "l": "+        });\n"}, {"t": "+", "n": 39, "l": "+        EventUtils.synthesizeKey(\"KEY_ArrowLeft\", { type: \"keyup\" });\n"}, {"t": "+", "n": 40, "l": "+        EventUtils.synthesizeKey(\"KEY_Meta\", { type: \"keyup\" });\n"}, {"t": "", "n": 41, "l": "       } else {\n"}, {"t": "-", "n": 42, "l": "-        EventUtils.synthesizeKey(\"KEY_Home\");\n"}, {"t": "+", "n": 43, "l": "+        EventUtils.synthesizeKey(\"KEY_ArrowLeft\", { ctrlKey: true });\n"}, {"t": "", "n": 44, "l": "       }\n"}, {"t": "", "n": 45, "l": "     },\n"}, {"t": "", "n": 46, "l": "     get modifiedSelection() {\n"}, {"t": "-", "n": 47, "l": "-      let start = gURLBar.value.indexOf(this._visibleValue);\n"}, {"t": "-", "n": 48, "l": "-      return [start, start];\n"}, {"t": "+", "n": 49, "l": "+      return [0, 0];\n"}, {"t": "+", "n": 50, "l": "+    },\n"}, {"t": "+", "n": 51, "l": "+  },\n"}, {"t": "+", "n": 52, "l": "+  {\n"}, {"t": "+", "n": 53, "l": "+    description: \"Test CTRL A starting from full selection\",\n"}, {"t": "+", "n": 54, "l": "+    skipIf() {\n"}, {"t": "+", "n": 55, "l": "+      return AppConstants.platform != \"macosx\";\n"}, {"t": "+", "n": 56, "l": "+    },\n"}, {"t": "+", "n": 57, "l": "+    openPanel() {\n"}, {"t": "+", "n": 58, "l": "+      EventUtils.synthesizeKey(\"l\", { accelKey: true });\n"}, {"t": "+", "n": 59, "l": "+    },\n"}, {"t": "+", "n": 60, "l": "+    get selection() {\n"}, {"t": "+", "n": 61, "l": "+      return [0, gURLBar.value.length];\n"}, {"t": "+", "n": 62, "l": "+    },\n"}, {"t": "+", "n": 63, "l": "+    manipulate() {\n"}, {"t": "+", "n": 64, "l": "+      EventUtils.synthesizeKey(\"A\", { ctrlKey: true });\n"}, {"t": "+", "n": 65, "l": "+    },\n"}, {"t": "+", "n": 66, "l": "+    get modifiedSelection() {\n"}, {"t": "+", "n": 67, "l": "+      return [0, 0];\n"}, {"t": "", "n": 68, "l": "     },\n"}, {"t": "", "n": 69, "l": "   },\n"}, {"t": "", "n": 70, "l": "   {\n"}, {"t": "", "n": 71, "l": "     description: \"Test END starting from full selection\",\n"}, {"t": "", "n": 72, "l": "     openPanel() {\n"}, {"t": "", "n": 73, "l": "       EventUtils.synthesizeKey(\"l\", { accelKey: true });\n"}, {"t": "", "n": 74, "l": "     },\n"}, {"t": "", "n": 75, "l": "     get selection() {\n"}, {"t": "@", "n": 76, "l": "@@ -214,16 +251,19 @@ add_task(async function https() {\n"}, {"t": "", "n": 77, "l": " add_task(async function http() {\n"}, {"t": "", "n": 78, "l": "   // eslint-disable-next-line @microsoft/sdl/no-insecure-url\n"}, {"t": "", "n": 79, "l": "   await doTest(\"http://example.com/test/other/page.htm\");\n"}, {"t": "", "n": 80, "l": " });\n"}, {"t": "", "n": 81, "l": " \n"}, {"t": "", "n": 82, "l": " async function doTest(url) {\n"}, {"t": "", "n": 83, "l": "   await BrowserTestUtils.withNewTab(url, async () => {\n"}, {"t": "", "n": 84, "l": "     for (let test of tests) {\n"}, {"t": "+", "n": 85, "l": "+      if (test.skipIf?.()) {\n"}, {"t": "+", "n": 86, "l": "+        continue;\n"}, {"t": "+", "n": 87, "l": "+      }\n"}, {"t": "", "n": 88, "l": "       gURLBar.blur();\n"}, {"t": "", "n": 89, "l": "       info(test.description);\n"}, {"t": "", "n": 90, "l": "       await UrlbarTestUtils.promisePopupOpen(window, async () => {\n"}, {"t": "", "n": 91, "l": "         await test.openPanel();\n"}, {"t": "", "n": 92, "l": "       });\n"}, {"t": "", "n": 93, "l": "       info(\n"}, {"t": "", "n": 94, "l": "         `Selected text is <${gURLBar.value.substring(\n"}, {"t": "", "n": 95, "l": "           gURLBar.selectionStart,\n"}]}], "phase": "public", "pushid": 41901, "pushdate": [1718358159, 0], "pushuser": "acseh@mozilla.com", "landingsystem": "lando", "git_commit": null}]