atch(/:\\/\\//)) {\n"}, {"line": "      input.value = \"https://\" + originValue;\n"}, {"line": "    }\n"}, {"line": "  }\n"}, {"line": "\n"}, {"line": "  get readonlyTemplate() {\n"}, {"line": "    return html`\n"}, {"line": "      <label\n"}, {"line": "        for=\"origin\"\n"}, {"line": "        class=\"field-label\"\n"}, {"line": "        data-l10n-id=\"login-item-origin-label\"\n"}, {"line": "      >\n"}, {"line": "      </label>\n"}, {"line": "      <a\n"}, {"line": "        id=\"origin\"\n"}, {"line": "        class=\"origin-input\"\n"}, {"line": "        dir=\"auto\"\n"}, {"line": "        target=\"_blank\"\n"}, {"line": "        rel=\"noreferrer\"\n"}, {"line": "        name=\"origin\"\n"}, {"line": "        href=${this.value}\n"}, {"line": "        @click=${this.onOriginClick}\n"}, {"line": "      >\n"}, {"line": "        ${this.value}\n"}, {"line": "      </a>\n"}, {"line": "    `;\n"}, {"line": "  }\n"}, {"line": "\n"}, {"line": "  render() {\n"}, {"line": "    return html`\n"}, {"line": "      ${stylesTemplate()}\n"}, {"line": "      ${this.readonly\n"}, {"line": "        ? this.readonlyTemplate\n"}, {"line": "        : editableFieldTemplate({\n"}, {"line": "            type: \"url\",\n"}, {"line": "            value: this.value,\n"}, {"line": "            required: this.required,\n"}, {"line": "            labelL10nId: \"login-item-origin-label\",\n"}, {"line": "            noteL10nId: \"contextual-manager-passwords-origin-tooltip\",\n"}, {"line": "            inputL10nId: \"login-item-origin\",\n"}, {"line": "            onBlur: e => this.addHTTPSPrefix(e),\n"}, {"line": "          })}\n"}, {"line": "    `;\n"}, {"line": "  }\n"}, {"line": "}\n"}, {"line": "\n"}, {"line": "customElements.define(\"login-origin-field\", LoginOriginField);\n"}]}]