3, "l": "   /**\n"}, {"t": "", "n": 44, "l": "    * Appends text content to the current node.\n"}, {"t": "", "n": 45, "l": "    *\n"}, {"t": "", "n": 46, "l": "    * @param aBuffer the buffer to copy from\n"}]}, {"blockno": 3, "lines": [{"t": "-", "n": 1, "l": "--- a/parser/html/nsHtml5TreeOperation.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/parser/html/nsHtml5TreeOperation.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -198,16 +198,18 @@ nsHtml5TreeOperation::~nsHtml5TreeOperat\n"}, {"t": "", "n": 4, "l": "       }\n"}, {"t": "", "n": 5, "l": "       if (aOperation.mOther) {\n"}, {"t": "", "n": 6, "l": "         aOperation.mOther->Release();\n"}, {"t": "", "n": 7, "l": "       }\n"}, {"t": "", "n": 8, "l": "     }\n"}, {"t": "", "n": 9, "l": " \n"}, {"t": "", "n": 10, "l": "     void operator()(const opAddLineNumberId& aOperation) {}\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "+", "n": 12, "l": "+    void operator()(const opShallowCloneInto& aOperation) {}\n"}, {"t": "+", "n": 13, "l": "+\n"}, {"t": "", "n": 14, "l": "     void operator()(const opStartLayout& aOperation) {}\n"}, {"t": "", "n": 15, "l": " \n"}, {"t": "", "n": 16, "l": "     void operator()(const opEnableEncodingMenu& aOperation) {}\n"}, {"t": "", "n": 17, "l": " \n"}, {"t": "", "n": 18, "l": "     void operator()(const uninitialized& aOperation) {\n"}, {"t": "", "n": 19, "l": "       NS_WARNING(\"Uninitialized tree op.\");\n"}, {"t": "", "n": 20, "l": "     }\n"}, {"t": "", "n": 21, "l": "   };\n"}, {"t": "@", "n": 22, "l": "@@ -1202,16 +1204,29 @@ nsresult nsHtml5TreeOperation::Perform(n\n"}, {"t": "", "n": 23, "l": "       Element* element = (*(aOperation.mElement))->AsElement();\n"}, {"t": "", "n": 24, "l": "       int32_t lineNumber = aOperation.mLineNumber;\n"}, {"t": "", "n": 25, "l": "       nsAutoString val(u\"line\"_ns);\n"}, {"t": "", "n": 26, "l": "       val.AppendInt(lineNumber);\n"}, {"t": "", "n": 27, "l": "       element->SetAttr(kNameSpaceID_None, nsGkAtoms::id, val, true);\n"}, {"t": "", "n": 2