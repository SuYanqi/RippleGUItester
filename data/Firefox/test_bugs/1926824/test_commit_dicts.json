);\n"}, {"t": "", "n": 8, "l": "     }\n"}, {"t": "", "n": 9, "l": "   };\n"}, {"t": "", "n": 10, "l": " };\n"}, {"t": "", "n": 11, "l": " \n"}, {"t": "+", "n": 12, "l": "+struct opShallowCloneInto {\n"}, {"t": "+", "n": 13, "l": "+  nsIContent** mSrc;\n"}, {"t": "+", "n": 14, "l": "+  nsIContent** mDst;\n"}, {"t": "+", "n": 15, "l": "+  nsIContent** mIntendedParent;\n"}, {"t": "+", "n": 16, "l": "+  mozilla::dom::FromParser mFromParser;\n"}, {"t": "+", "n": 17, "l": "+\n"}, {"t": "+", "n": 18, "l": "+  opShallowCloneInto(nsIContentHandle* aSrc, nsIContentHandle* aDst,\n"}, {"t": "+", "n": 19, "l": "+                     nsIContentHandle* aIntendedParent,\n"}, {"t": "+", "n": 20, "l": "+                     mozilla::dom::FromParser aFromParser)\n"}, {"t": "+", "n": 21, "l": "+      : mFromParser(aFromParser) {\n"}, {"t": "+", "n": 22, "l": "+    mSrc = static_cast<nsIContent**>(aSrc);\n"}, {"t": "+", "n": 23, "l": "+    mDst = static_cast<nsIContent**>(aDst);\n"}, {"t": "+", "n": 24, "l": "+    mIntendedParent = static_cast<nsIContent**>(aIntendedParent);\n"}, {"t": "+", "n": 25, "l": "+  };\n"}, {"t": "+", "n": 26, "l": "+};\n"}, {"t": "+", "n": 27, "l": "+\n"}, {"t": "", "n": 28, "l": " struct opAddLineNumberId {\n"}, {"t": "", "n": 29, "l": "   nsIContent** mElement;\n"}, {"t": "", "n": 30, "l": "   int32_t mLineNumber;\n"}, {"t": "", "n": 31, "l": " \n"}, {"t": "", "n": 32, "l": "   explicit opAddLineNumberId(nsIContentHandle* aElement, int32_t aLineNumber)\n"}, {"t": "", "n": 33, "l": "       : mLineNumber(aLineNumber) {\n"}, {"t": "", "n": 34, "l": "     mElement = static_cast<nsIContent**>(aElement);\n"}, {"t": "", "n": 35, "l": "   };\n"}, {"t": "@", "n": 36, "l": "@@ -539,17 +555,17 @@ typedef mozilla::Variant<\n"}, {"t": "", "n": 37, "l": "     opMarkAsBroken, opRunScriptThatMayDocumentWriteOrBlock,\n"}, {"t": "", "n": 38, "l": "     opRunScriptThatCannotDocumentWriteOrBlock, opPreventScriptExecution,\n"}, {"t": "", "n": 39, "l": "     opDoneAddingChildren