[{"node": "7b4d4dd9711272104a253a787f1f7582dcb7e2ec", "date": [1729848440.0, 0], "desc": "Bug 1926824 - Generate one block per line in the view source highlighter. r=hsivonen\n\nThis makes viewing source of the HTML spec usable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D226794", "backedoutby": "", "branch": "default", "bookmarks": [], "tags": [], "user": "Emilio Cobos \u00c1lvarez <emilio@crisal.io>", "parents": ["1a1c3bb073cd5c3c12637dd6d8e5999e8f932adc"], "children": ["fd1ad91ca6edeb83aea7b9d03a1eca406248cafc"], "files": [{"file": "parser/html/nsHtml5Highlighter.cpp", "status": "modified"}, {"file": "parser/html/nsHtml5Highlighter.h", "status": "modified"}, {"file": "parser/html/nsHtml5TreeOperation.cpp", "status": "modified"}, {"file": "parser/html/nsHtml5TreeOperation.h", "status": "modified"}], "diff": [{"blockno": 1, "lines": [{"t": "-", "n": 1, "l": "--- a/parser/html/nsHtml5Highlighter.cpp\n"}, {"t": "+", "n": 2, "l": "+++ b/parser/html/nsHtml5Highlighter.cpp\n"}, {"t": "@", "n": 3, "l": "@@ -556,38 +556,65 @@ void nsHtml5Highlighter::FlushChars() {\n"}, {"t": "", "n": 4, "l": "           [[fallthrough]];\n"}, {"t": "", "n": 5, "l": "         case '\\n': {\n"}, {"t": "", "n": 6, "l": "           ++i;\n"}, {"t": "", "n": 7, "l": "           if (mCStart < i) {\n"}, {"t": "", "n": 8, "l": "             int32_t len = i - mCStart;\n"}, {"t": "", "n": 9, "l": "             AppendCharacters(buf, mCStart, len);\n"}, {"t": "", "n": 10, "l": "             mCStart = i;\n"}, {"t": "", "n": 11, "l": "           }\n"}, {"t": "-", "n": 12, "l": "-          ++mLineNumber;\n"}, {"t": "-", "n": 13, "l": "-          Push(nsGkAtoms::span, nullptr, NS_NewHTMLSpanElement);\n"}, {"t": "-", "n": 14, "l": "-          nsHtml5TreeOperation* treeOp = mOpQueue.AppendElement();\n"}, {"t": "-", "n": 15, "l": "-          NS_ASSERTION(treeOp, \"Tree op allocation failed.\");\n"}, {"t": "-", "n": 16, "l": "-          opAddLineNumberId operation(CurrentNode(), mLineNumber);\n"}, {"t": "-", "n": 17, "l": "-          treeOp->Init(mozilla::AsVariant(operation));\n"}, {"t": "-", "n": 18, "l": "-          Pop();\n"}, {"t": "+", "n": 19, "l": "+          NewLine();\n"}, {"t": "", "n": 20, "l": "           break;\n"}, {"t": "", "n": 21, "l": "         }\n"}, {"t": "", "n": 22, "l": "         default:\n"}, {"t": "", "n": 23, "l": "           ++i;\n"}, {"t": "", "n": 24, "l": "           break;\n"}, {"t": "", "n": 25, "l": "       }\n"}, {"t": "", "n": 26, "l": "     }\n"}, {"t": "", "n": 27, "l": "     if (mCStart < mPos) {\n"}, {"t": "", "n": 28, "l": "       int32_t len = mPos - mCStart;\n"}, {"t": "", "n": 29, "l": "       AppendCharacters(buf, mCStart, len);\n"}, {"t": "", "n": 30, "l": "       mCStart = mPos;\n"}, {"t": "", "n": 31, "l": "     }\n"}, {"t": "", "n": 32, "l": "   }\n"}, {"t": "", "n": 33, "l": " }\n"}, {"t": "", "n": 34, "l": " \n"}, {"t": "+", "n": 35, "l": "+// NOTE(emilio): It's important that nothing here ends up calling FlushChars(),\n"}, {"t": "+", "n": 36, "l": "+// since we're in the middle of a flush.\n"}, {"t": "+", "n": 37, "l": "+void nsHtml5Highlighter::NewLine() {\n"}, {"t": "+", "n": 38, "l": "+  ++mLineNumber;\n"}, {"t": "+", "n": 39, "l": "+  AutoTArray<nsIContent**, 8> handleStack;\n"}, {"t": "+", "n": 40, "l": "+  const bool wasInCharacters = mInCharacters;\n"}, {"t": "+", "n": 41, "l": "+  if (mInCharacters) {\n"}, {"t": "+", "n": 42, "l": "+    Pop();\n"}, {"t": "+", "n": 43, "l": "+    mInCharacters = false;\n"}, {"t": "+", "n": 44, "l": "+  }\n"}, {"t": "+", "n": 45, "l": "+  while (mInlinesOpen) {\n"}, {"t": "+", "n": 46, "l": "+    handleStack.AppendElement(CurrentNode());\n"}, {"t": "+", "n": 47, "l": "+    Pop();\n"}, {"t": "+", "n": 48, "l": "+    mInlinesOpen--;\n"}, {"t": "+", "n": 49, "l": "+  }\n"}, {"t": "+", "n": 50, "l": "+  Pop();  // Pop the <pre>\n"}, {"t": "+", "n": 51, "l": "+  Push(nsGkAtoms::pre, nullptr, NS_NewHTMLPreElement);\n"}, {"t": "+", "n": 52, "l": "+  mOpQueue.AppendElement()->Init(\n"}, {"t": "+", "n": 53, "l": "+      mozilla::AsVariant(opAddLineNumberId(CurrentNode(), mLineNumber)));\n"}, {"t": "+", "n": 54, "l": "+  for (nsIContent** handle : Reversed(handleStack)) {\n"}, {"t": "+", "n": 55, "l": "+    nsIContent** dest = AllocateContentHandle();\n"}, {"t": "+", "n": 56, "l": "+    mOpQueue.AppendElement()->Init(mozilla::AsVariant(opShallowCloneInto(\n"}, {"t": "+", "n": 57, "l": "+        handle, dest, CurrentNode(), mozilla::dom::FROM_PARSER_NETWORK)));\n"}, {"t": "+", "n": 58, "l": "+    mStack.AppendElement(dest);\n"}, {"t": "+", "n": 59, "l": "+    ++mInlinesOpen;\n"}, {"t": "+", "n": 60, "l": "+  }\n"}, {"t": "+", "n": 61, "l": "+  if (wasInCharacters) {\n"}, {"t": "+", "n": 62, "l": "+    Push(nsGkAtoms::span, nullptr, NS_NewHTMLSpanElement);\n"}, {"t": "+", "n": 63, "l": "+    mCurrentRun = CurrentNode();\n"}, {"t": "+", "n": 64, "l": "+    mInCharacters = true;\n"}, {"t": "+", "n": 65, "l": "+  }\n"}, {"t": "+", "n": 66, "l": "+}\n"}, {"t": "+", "n": 67, "l": "+\n"}, {"t": "", "n": 68, "l": " void nsHtml5Highlighter::FlushCurrent() {\n"}, {"t": "", "n": 69, "l": "   mPos++;\n"}, {"t": "", "n": 70, "l": "   FlushChars();\n"}, {"t": "", "n": 71, "l": " }\n"}, {"t": "", "n": 72, "l": " \n"}, {"t": "", "n": 73, "l": " bool nsHtml5Highlighter::ShouldFlushOps() {\n"}, {"t": "", "n": 74, "l": "   // Arbitrary threshold that doesn't have an exact justification.\n"}, {"t": "", "n": 75, "l": "   // The general idea is to flush much, much sooner than reaching\n"}, {"t": "@", "n": 76, "l": "@@ -646,24 +673,24 @@ nsIContent** nsHtml5Highlighter::CreateE\n"}, {"t": "", "n": 77, "l": "   opCreateHTMLElement opeation(content, aName, aAttributes, aCreator,\n"}, {"t": "", "n": 78, "l": "                                aIntendedParent,\n"}, {"t": "", "n": 79, "l": "                                mozilla::dom::FROM_PARSER_NETWORK);\n"}, {"t": "", "n": 80, "l": "   mOpQueue.AppendElement()->Init(mozilla::AsVariant(opeation));\n"}, {