[{"sha": "b86b57919684d658bf75042f22c83927e075aa46", "node_id": "C_kwDOBuGRQdoAKGI4NmI1NzkxOTY4NGQ2NThiZjc1MDQyZjIyYzgzOTI3ZTA3NWFhNDY", "commit": {"author": {"name": "benniekiss", "email": "63211101+benniekiss@users.noreply.github.com", "date": "2025-12-08T16:17:36Z"}, "committer": {"name": "benniekiss", "email": "63211101+benniekiss@users.noreply.github.com", "date": "2025-12-08T16:18:39Z"}, "message": "use `line.moveBase`, not `ctx.nextLine`\n\n* this is the correct way to move parsing forward", "tree": {"sha": "d5c485674ef619ae907a80336d66247e8ff970ce", "url": "https://api.github.com/repos/Zettlr/Zettlr/git/trees/d5c485674ef619ae907a80336d66247e8ff970ce"}, "url": "https://api.github.com/repos/Zettlr/Zettlr/git/commits/b86b57919684d658bf75042f22c83927e075aa46", "comment_count": 0, "verification": {"verified": false, "reason": "unsigned", "signature": null, "payload": null, "verified_at": null}}, "url": "https://api.github.com/repos/Zettlr/Zettlr/commits/b86b57919684d658bf75042f22c83927e075aa46", "html_url": "https://github.com/Zettlr/Zettlr/commit/b86b57919684d658bf75042f22c83927e075aa46", "comments_url": "https://api.github.com/repos/Zettlr/Zettlr/commits/b86b57919684d658bf75042f22c83927e075aa46/comments", "author": {"login": "benniekiss", "id": 63211101, "node_id": "MDQ6VXNlcjYzMjExMTAx", "avatar_url": "https://avatars.githubusercontent.com/u/63211101?v=4", "gravatar_id": "", "url": "https://api.github.com/users/benniekiss", "html_url": "https://github.com/benniekiss", "followers_url": "https://api.github.com/users/benniekiss/followers", "following_url": "https://api.github.com/users/benniekiss/following{/other_user}", "gists_url": "https://api.github.com/users/benniekiss/gists{/gist_id}", "starred_url": "https://api.github.com/users/benniekiss/starred{/owner}{/repo}", "subscriptions_url": "https://api.github.com/users/benniekiss/subscriptions", "organizations_url": "https://api.github.com/users/benniekiss/orgs", "repos_url": "https://api.github.com/users/benniekiss/repos", "events_url": "https://api.github.com/users/benniekiss/events{/privacy}", "received_events_url": "https://api.github.com/users/benniekiss/received_events", "type": "User", "user_view_type": "public", "site_admin": false}, "committer": {"login": "benniekiss", "id": 63211101, "node_id": "MDQ6VXNlcjYzMjExMTAx", "avatar_url": "https://avatars.githubusercontent.com/u/63211101?v=4", "gravatar_id": "", "url": "https://api.github.com/users/benniekiss", "html_url": "https://github.com/benniekiss", "followers_url": "https://api.github.com/users/benniekiss/followers", "following_url": "https://api.github.com/users/benniekiss/following{/other_user}", "gists_url": "https://api.github.com/users/benniekiss/gists{/gist_id}", "starred_url": "https://api.github.com/users/benniekiss/starred{/owner}{/repo}", "subscriptions_url": "https://api.github.com/users/benniekiss/subscriptions", "organizations_url": "https://api.github.com/users/benniekiss/orgs", "repos_url": "https://api.github.com/users/benniekiss/repos", "events_url": "https://api.github.com/users/benniekiss/events{/privacy}", "received_events_url": "https://api.github.com/users/benniekiss/received_events", "type": "User", "user_view_type": "public", "site_admin": false}, "parents": [{"sha": "6d36774f648e5ec66c4f99999cd9c75aa1b9fc72", "url": "https://api.github.com/repos/Zettlr/Zettlr/commits/6d36774f648e5ec66c4f99999cd9c75aa1b9fc72", "html_url": "https://github.com/Zettlr/Zettlr/commit/6d36774f648e5ec66c4f99999cd9c75aa1b9fc72"}], "stats": {"total": 24, "additions": 22, "deletions": 2}, "files": [{"sha": "df2db9d20fafb0f3c2842e799c4908320dc7d6e2", "filename": "source/common/modules/markdown-editor/parser/pandoc-div-span-parser.ts", "status": "modified", "additions": 22, "deletions": 2, "changes": 24, "blob_url": "https://github.com/Zettlr/Zettlr/blob/b86b57919684d658bf75042f22c83927e075aa46/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts", "raw_url": "https://github.com/Zettlr/Zettlr/raw/b86b57919684d658bf75042f22c83927e075aa46/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts", "contents_url": "https://api.github.com/repos/Zettlr/Zettlr/contents/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts?ref=b86b57919684d658bf75042f22c83927e075aa46", "patch": "@@ -79,6 +79,13 @@ export const pandocSpanParser: InlineParser = {\n export const pandocDivParser: BlockParser = {\n   name: 'pandoc-div',\n   parse: (ctx, line) => {\n+    // Opening marks can only occur at the beginning of the line.\n+    // Likewise, to avoid infinitely re-parsing the line, we only\n+    // start testing the block if we are at the beginning.\n+    if (line.pos > 0) {\n+      return false\n+    }\n+\n     // Valid lines have the pattern `::: {#id .classes key=value}`.\n     const match = pandocDivOpeningRe.exec(line.text)\n     if (!match?.indices?.groups) {\n@@ -101,15 +108,25 @@ export const pandocDivParser: BlockParser = {\n     // mark.\n     ctx.startComposite('PandocDiv', 0, ctx.depth + 1)\n \n+    // We need to move the line position after parsing,\n+    // so we track the offset as we calculate markers\n+    // This is a line-relative position, not document-\n+    // relative.\n+    let lineBasePos = 0\n+\n     // Opening mark\n     const [ markFrom, markTo ] = match.indices.groups.mark\n     ctx.addElement(ctx.elt('PandocDivMark', ctx.lineStart + markFrom, ctx.lineStart + markTo))\n \n+    lineBasePos = markTo\n+\n     // Bare class names\n     if (match.groups?.name !== undefined || match.groups?.class !== undefined) {\n       const [ classFrom, classTo ] = match.indices.groups.name ?? match.indices.groups.class\n \n       ctx.addElement(ctx.elt('PandocDivInfo', ctx.lineStart + classFrom, ctx.lineStart + classTo))\n+\n+      lineBasePos = classTo\n     }\n \n     // `PandocAttribute` nodes\n@@ -129,12 +146,15 @@ export const pandocDivParser: BlockParser = {\n         const nodeId = ctx.parser.nodeSet.types.find(node => node.is('PandocAttribute'))?.id\n         if (attr[0].type === nodeId) {\n           ctx.addElement(attr[0])\n+\n+          lineBasePos = attrTo\n         }\n       }\n     }\n \n-    // We consume the whole line since there can be no other content\n-    ctx.nextLine()\n+    // Move the base position to avoid infinite loops\n+    line.moveBase(lineBasePos)\n+\n     return null // composite blocks require returning `null` on success\n   },\n "}]}, {"sha": "b51b1e00ad130e6e4e65e42a88c8c04a5403f816", "node_id": "C_kwDOBuGRQdoAKGI1MWIxZTAwYWQxMzBlNmU0ZTY1ZTQyYTg4YzhjMDRhNTQwM2Y4MTY", "commit": {"author": {"name": "benniekiss", "email": "63211101+benniekiss@users.noreply.github.com", "date": "2025-12-08T16:45:29Z"}, "committer": {"name": "benniekiss", "email": "63211101+benniekiss@users.noreply.github.com", "date": "2025-12-08T16:45:29Z"}, "message": "space between div mark and attributes is optional", "tree": {"sha": "da7acc828807846594236f628302d8e0c36c526e", "url": "https://api.github.com/repos/Zettlr/Zettlr/git/trees/da7acc828807846594236f628302d8e0c36c526e"}, "url": "https://api.github.com/repos/Zettlr/Zettlr/git/commits/b51b1e00ad130e6e4e65e42a88c8c04a5403f816", "comment_count": 0, "verification": {"verified": false, "reason": "unsigned", "signature": null, "payload": null, "verified_at": null}}, "url": "https://api.github.com/repos/Zettlr/Zettlr/commits/b51b1e00ad130e6e4e65e42a88c8c04a5403f816", "html_url": "https://github.com/Zettlr/Zettlr/commit/b51b1e00ad130e6e4e65e42a88c8c04a5403f816", "comments_url": "https://api.github.com/repos/Zettlr/Zettlr/commits/b51b1e00ad130e6e4e65e42a88c8c04a5403f816/comments", "author": {"login": "benniekiss", "id": 63211101, "node_id": "MDQ6VXNlcjYzMjExMTAx", "avatar_url": "https://avatars.githubusercontent.com/u/63211101?v=4", "gravatar_id": "", "url": "https://api.github.com/users/benniekiss", "html_url": "https://github.com/benniekiss", "followers_url": "https://api.github.com/users/benniekiss/followers", "followin