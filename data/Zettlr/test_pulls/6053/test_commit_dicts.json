a": "22b284893ad8db4078e8bf275557dd6d807690e9", "filename": "source/common/modules/markdown-editor/parser/pandoc-div-span-parser.ts", "status": "modified", "additions": 1, "deletions": 1, "changes": 2, "blob_url": "https://github.com/Zettlr/Zettlr/blob/b51b1e00ad130e6e4e65e42a88c8c04a5403f816/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts", "raw_url": "https://github.com/Zettlr/Zettlr/raw/b51b1e00ad130e6e4e65e42a88c8c04a5403f816/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts", "contents_url": "https://api.github.com/repos/Zettlr/Zettlr/contents/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts?ref=b51b1e00ad130e6e4e65e42a88c8c04a5403f816", "patch": "@@ -19,7 +19,7 @@ const PandocSpanDelimiter: DelimiterType = {}\n \n const pandocSpanClosingRe = /^\\](?<attr>\\{[ \\w\\t\\-.#:=;\"')(]*\\})/d\n \n-const pandocDivOpeningRe = /^(?<mark>:{3,})[ \\t]+(?:(?<name>[\\w\\-.]+)|(?:(?<class>[\\w\\-.]+)[ \\t]+)?(?<attr>\\{[ \\w\\t\\-.#:=;\"')(]*\\}))\\s*$/d\n+const pandocDivOpeningRe = /^(?<mark>:{3,})[ \\t]*(?:(?<name>[\\w\\-.]+)|(?:(?<class>[\\w\\-.]+)[ \\t]+)?(?<attr>\\{[ \\w\\t\\-.%#:=;\"')(]*\\}))\\s*$/d\n \n const pandocDivClosingRe = /^(?<mark>:{3,})\\s*$/d\n "}]}, {"sha": "405bfa07c75e43a45a11f127aef8617e5b91c866", "node_id": "C_kwDOBuGRQdoAKDQwNWJmYTA3Yzc1ZTQzYTQ1YTExZjEyN2FlZjg2MTdlNWI5MWM4NjY", "commit": {"author": {"name": "benniekiss", "email": "63211101+benniekiss@users.noreply.github.com", "date": "2025-12-08T16:46:14Z"}, "committer": {"name": "benniekiss", "email": "63211101+benniekiss@users.noreply.github.com", "date": "2025-12-08T16:46:14Z"}, "message": "fix nested div opening parsing", "tree": {"sha": "643fbff6d925b0382e092270dbdd6959fc24b0cf", "url": "https://api.github.com/repos/Zettlr/Zettlr/git/trees/643fbff6d925b0382e092270dbdd6959fc24b0cf"}, "url": "https://api.github.com/repos/Zettlr/Zettlr/git/commits/405bfa07c75e43a45a11f127aef8617e5b91c866", "comment_count": 0, "verification": {"verified": false, "reason": "unsigned", "signature": null, "payload": null, "verified_at": null}}, "url": "https://api.github.com/repos/Zettlr/Zettlr/commits/405bfa07c75e43a45a11f127aef8617e5b91c866", "html_url": "https://github.com/Zettlr/Zettlr/commit/405bfa07c75e43a45a11f127aef8617e5b91c866", "comments_url": "https://api.github.com/repos/Zettlr/Zettlr/commits/405bfa07c75e43a45a11f127aef8617e5b91c866/comments", "author": {"login": "benniekiss", "id": 63211101, "node_id": "MDQ6VXNlcjYzMjExMTAx", "avatar_url": "https://avatars.githubusercontent.com/u/63211101?v=4", "gravatar_id": "", "url": "https://api.github.com/users/benniekiss", "html_url": "https://github.com/benniekiss", "followers_url": "https://api.github.com/users/benniekiss/followers", "following_url": "https://api.github.com/users/benniekiss/following{/other_user}", "gists_url": "https://api.github.com/users/benniekiss/gists{/gist_id}", "starred_url": "https://api.github.com/users/benniekiss/starred{/owner}{/repo}", "subscriptions_url": "https://api.github.com/users/benniekiss/subscriptions", "organizations_url": "https://api.github.com/users/benniekiss/orgs", "repos_url": "https://api.github.com/users/benniekiss/repos", "events_url": "https://api.github.com/users/benniekiss/events{/privacy}", "received_events_url": "https://api.github.com/users/benniekiss/received_events", "type": "User", "user_view_type": "public", "site_admin": false}, "committer": {"login": "benniekiss", "id": 63211101, "node_id": "MDQ6VXNlcjYzMjExMTAx", "avatar_url": "https://avatars.githubusercontent.com/u/63211101?v=4", "gravatar_id": "", "url": "https://api.github.com/users/benniekiss", "html_url": "https://github.com/benniekiss", "followers_url": "https://api.github.com/users/benniekiss/followers", "following_url": "https://api.github.com/users/benniekiss/following{/other_user}", "gists_url": "https://api.github.com/users/benniekiss/gists{/gist_id}", "starred_url": "https://api.github.com/users/benniekiss/starred{/owner}{/repo}", "subscriptions_url": "https://api.github.com/users/benniekiss/subscriptions", "organizations_url": "https://api.github.com/users/benniekiss/orgs", "repos_url": "https://api.github.com/users/benniekiss/repos", "events_url": "https://api.github.com/users/benniekiss/events{/privacy}", "received_events_url": "https://api.github.com/users/benniekiss/received_events", "type": "User", "user_view_type": "public", "site_admin": false}, "parents": [{"sha": "b51b1e00ad130e6e4e65e42a88c8c04a5403f816", "url": "https://api.github.com/repos/Zettlr/Zettlr/commits/b51b1e00ad130e6e4e65e42a88c8c04a5403f816", "html_url": "https://github.com/Zettlr/Zettlr/commit/b51b1e00ad130e6e4e65e42a88c8c04a5403f816"}], "stats": {"total": 10, "additions": 9, "deletions": 1}, "files": [{"sha": "c0d38a03637c7c467cc3a3dffa03708a563ebbf3", "filename": "source/common/modules/markdown-editor/parser/pandoc-div-span-parser.ts", "status": "modified", "additions": 9, "deletions": 1, "changes": 10, "blob_url": "https://github.com/Zettlr/Zettlr/blob/405bfa07c75e43a45a11f127aef8617e5b91c866/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts", "raw_url": "https://github.com/Zettlr/Zettlr/raw/405bfa07c75e43a45a11f127aef8617e5b91c866/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts", "contents_url": "https://api.github.com/repos/Zettlr/Zettlr/contents/source%2Fcommon%2Fmodules%2Fmarkdown-editor%2Fparser%2Fpandoc-div-span-parser.ts?ref=405bfa07c75e43a45a11f127aef8617e5b91c866", "patch": "@@ -158,7 +158,15 @@ export const pandocDivParser: BlockParser = {\n     return null // composite blocks require returning `null` on success\n   },\n \n-  endLeaf: (_ctx, line, _leaf) => {\n+  endLeaf: (ctx, line, _leaf) => {\n+    // Opening marks can come one after the other without requiring\n+    // a blank line in between. So we only interrupt if the line matches\n+    // the opening mark if the parent is a `PandocDiv`. Otherrwise,\n+    // only the closing mark can interrupt other nodes.\n+    if (ctx.parentType().name === 'PandocDiv') {\n+      return pandocDivClosingRe.test(line.text) || pandocDivOpeningRe.test(line.text)\n+    }\n+\n     return pandocDivClosingRe.test(line.text)\n   }\n }"}]}]